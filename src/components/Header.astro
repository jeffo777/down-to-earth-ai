---
/**
 * Header.astro — Sticky site header with nav + mobile hamburger
 */
const navLinks = [
  { label: 'Home', href: '/' },
  {
    label: 'Services',
    children: [
      { label: 'Lead Generation', href: '/lead-generation-for-tradesmen', overview: true },
      { label: 'divider' },
      { label: 'AI Receptionist', href: '/ai-receptionist-for-tradesmen' },
      { label: 'Lead Generation Websites', href: '/lead-generation-websites-for-tradesmen' },
      { label: 'AI Marketing', href: '/ai-marketing-for-tradesmen' },
      { label: 'Custom AI Automations', href: '/custom-ai-automations-for-tradesmen' },
    ]
  },
  { label: 'Pricing', href: '/pricing' },
  { label: 'About', href: '/about' },
  { label: 'Contact', href: '/contact' },
];
---

<header class="header" id="site-header">
  <a href="#main-content" class="skip-to-content">Skip to content</a>

  <div class="header__inner">
    <!-- Logo -->
    <a href="/" class="header__logo" aria-label="Down To Earth AI — Home">
      <span class="header__logo-text">Down To Earth <span class="header__logo-accent">AI</span></span>
    </a>

    <!-- Desktop Nav -->
    <nav class="header__nav" aria-label="Main navigation">
      {navLinks.map(link => (
        link.children ? (
          <div class="header__dropdown">
            <button
              class="header__nav-link header__dropdown-trigger"
              aria-expanded="false"
              aria-haspopup="true"
            >
              {link.label}
              <svg class="header__chevron" width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
            </button>
            <div class="header__dropdown-menu" role="menu">
              {link.children.map(child => (
                child.label === 'divider' ? (
                  <div class="header__dropdown-divider"></div>
                ) : (
                  <a href={child.href} class={`header__dropdown-item ${child.overview ? 'header__dropdown-item--overview' : ''}`} role="menuitem">
                    {child.label}
                    {child.overview && <span class="header__dropdown-subtitle">The full system — overview</span>}
                  </a>
                )
              ))}
            </div>
          </div>
        ) : (
          <a href={link.href} class="header__nav-link">{link.label}</a>
        )
      ))}
    </nav>

    <!-- CTA + Hamburger -->
    <div class="header__actions">
      <a href="/get-started" class="header__cta">Get Started</a>
      <button
        class="header__hamburger"
        aria-label="Open menu"
        aria-expanded="false"
        id="hamburger-btn"
      >
        <span class="header__hamburger-line"></span>
        <span class="header__hamburger-line"></span>
        <span class="header__hamburger-line"></span>
      </button>
    </div>
  </div>

  <!-- Mobile Menu -->
  <div class="mobile-menu" id="mobile-menu" aria-hidden="true">
    <nav class="mobile-menu__nav" aria-label="Mobile navigation">
      {navLinks.map(link => (
        link.children ? (
          <>
            <span class="mobile-menu__label">{link.label}</span>
            <div class="mobile-menu__sub">
              {link.children.map(child => (
                child.label === 'divider' ? (
                  <div class="mobile-menu__divider"></div>
                ) : (
                  <a href={child.href} class={`mobile-menu__link mobile-menu__link--sub ${child.overview ? 'mobile-menu__link--overview' : ''}`}>{child.label}</a>
                )
              ))}
            </div>
          </>
        ) : (
          <a href={link.href} class="mobile-menu__link">{link.label}</a>
        )
      ))}
      <a href="/get-started" class="mobile-menu__cta">Get Started</a>
    </nav>
  </div>
</header>

<style>
  /* Header Base */
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 50;
    background: rgba(15, 17, 23, 0.92);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border-subtle);
    height: 64px;
  }

  .header__inner {
    max-width: 72rem;
    margin: 0 auto;
    padding: 0 1rem;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: space-between;
  }

  /* Logo */
  .header__logo {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-text-primary);
    font-weight: 800;
    font-size: 1.125rem;
    text-decoration: none;
    flex-shrink: 0;
  }

  .header__logo:hover {
    color: var(--color-text-primary);
  }

  .header__logo-accent {
    color: var(--color-accent);
  }

  /* Desktop Nav */
  .header__nav {
    display: none;
    align-items: center;
    gap: 0.25rem;
  }

  @media (min-width: 1024px) {
    .header__nav { display: flex; }
  }

  .header__nav-link {
    color: var(--color-text-secondary);
    padding: 0.5rem 0.75rem;
    font-size: 0.9rem;
    font-weight: 500;
    border-radius: 0.5rem;
    transition: color 150ms, background 150ms;
    text-decoration: none;
    cursor: pointer;
    background: none;
    border: none;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 0.25rem;
  }

  .header__nav-link:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  /* Dropdown */
  .header__dropdown {
    position: relative;
  }

  .header__chevron {
    transition: transform 200ms;
  }

  .header__dropdown:hover .header__chevron,
  .header__dropdown.open .header__chevron {
    transform: rotate(180deg);
  }

  .header__dropdown-menu {
    position: absolute;
    top: 100%;
    left: 0;
    min-width: 240px;
    padding: 0.5rem;
    background: var(--color-secondary);
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.75rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.4);
    opacity: 0;
    visibility: hidden;
    transform: translateY(4px);
    transition: opacity 200ms, transform 200ms, visibility 200ms;
  }

  .header__dropdown:hover .header__dropdown-menu,
  .header__dropdown.open .header__dropdown-menu {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  .header__dropdown-item {
    display: block;
    padding: 0.625rem 0.875rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    border-radius: 0.5rem;
    transition: color 150ms, background 150ms;
    text-decoration: none;
  }

  .header__dropdown-item--overview {
    display: flex;
    flex-direction: column;
    gap: 0.125rem;
    color: var(--color-accent);
    font-weight: 600;
  }

  .header__dropdown-subtitle {
    font-size: 0.7rem;
    font-weight: 400;
    color: var(--color-text-muted);
  }

  .header__dropdown-divider {
    height: 1px;
    background: var(--color-border-subtle);
    margin: 0.375rem 0.5rem;
  }

  .header__dropdown-item:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  /* Actions */
  .header__actions {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .header__cta {
    display: inline-flex;
    align-items: center;
    padding: 0.5rem 1.25rem;
    background: var(--color-accent);
    color: #fff;
    font-weight: 600;
    font-size: 0.875rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 150ms, transform 150ms;
  }

  .header__cta:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: scale(1.02);
  }

  /* Hamburger */
  .header__hamburger {
    display: flex;
    flex-direction: column;
    justify-content: center;
    gap: 5px;
    width: 44px;
    height: 44px;
    padding: 10px;
    background: none;
    border: none;
    cursor: pointer;
  }

  @media (min-width: 1024px) {
    .header__hamburger { display: none; }
  }

  .header__hamburger-line {
    display: block;
    width: 100%;
    height: 2px;
    background: var(--color-text-secondary);
    border-radius: 2px;
    transition: transform 300ms, opacity 200ms;
  }

  .header__hamburger.active .header__hamburger-line:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .header__hamburger.active .header__hamburger-line:nth-child(2) {
    opacity: 0;
  }
  .header__hamburger.active .header__hamburger-line:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }

  /* Mobile Menu */
  .mobile-menu {
    position: fixed;
    top: 64px;
    left: 0;
    right: 0;
    bottom: 0;
    background: var(--color-primary);
    padding: 1.5rem;
    opacity: 0;
    visibility: hidden;
    transform: translateY(-8px);
    transition: opacity 250ms, transform 250ms, visibility 250ms;
    z-index: 49;
    overflow-y: auto;
  }

  .mobile-menu.open {
    opacity: 1;
    visibility: visible;
    transform: translateY(0);
  }

  @media (min-width: 1024px) {
    .mobile-menu { display: none !important; }
  }

  .mobile-menu__nav {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .mobile-menu__link {
    display: block;
    padding: 0.875rem 0.75rem;
    color: var(--color-text-primary);
    font-size: 1.125rem;
    font-weight: 600;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 150ms;
  }

  .mobile-menu__link:hover {
    background: rgba(255, 255, 255, 0.05);
    color: var(--color-text-primary);
  }

  .mobile-menu__label {
    display: block;
    padding: 0.875rem 0.75rem 0.25rem;
    color: var(--color-text-muted);
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .mobile-menu__link--overview {
    color: var(--color-accent) !important;
    font-weight: 600 !important;
  }

  .mobile-menu__divider {
    height: 1px;
    background: var(--color-border-subtle);
    margin: 0.25rem 1rem;
  }

  .mobile-menu__link--sub {
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    padding-left: 1.5rem;
  }

  .mobile-menu__cta {
    display: block;
    margin-top: 1rem;
    padding: 1rem;
    background: var(--color-accent);
    color: #fff;
    font-weight: 700;
    font-size: 1.125rem;
    text-align: center;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: background 150ms;
  }

  .mobile-menu__cta:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }
</style>

<script>
  // Hamburger toggle
  const hamburger = document.getElementById('hamburger-btn');
  const mobileMenu = document.getElementById('mobile-menu');

  if (hamburger && mobileMenu) {
    hamburger.addEventListener('click', () => {
      const isOpen = mobileMenu.classList.toggle('open');
      hamburger.classList.toggle('active');
      hamburger.setAttribute('aria-expanded', String(isOpen));
      mobileMenu.setAttribute('aria-hidden', String(!isOpen));
      document.body.style.overflow = isOpen ? 'hidden' : '';
    });
  }

  // Desktop dropdown toggle (click + hover)
  document.querySelectorAll('.header__dropdown-trigger').forEach(btn => {
    btn.addEventListener('click', () => {
      const dropdown = btn.closest('.header__dropdown');
      if (dropdown) {
        dropdown.classList.toggle('open');
        btn.setAttribute('aria-expanded',
          String(dropdown.classList.contains('open'))
        );
      }
    });
  });

  // Close dropdown on outside click
  document.addEventListener('click', (e) => {
    document.querySelectorAll('.header__dropdown.open').forEach(d => {
      if (!d.contains(e.target as Node)) {
        d.classList.remove('open');
        const trigger = d.querySelector('.header__dropdown-trigger');
        trigger?.setAttribute('aria-expanded', 'false');
      }
    });
  });
</script>
