---
/**
 * WidgetJaina.astro — Persistent bottom-right AI receptionist widget
 * Shows receptionist headshot with pulsing orange ring.
 * Click to reveal chat/call options.
 * Hides when HeroJaina section is in viewport via IntersectionObserver.
 */
import { SITE_CONFIG } from '../config/site.js';

interface Props {
  widgetTrade?: string;
  widgetGoal?: string;
}

const { widgetTrade = '', widgetGoal = '' } = Astro.props;
const aiActive = SITE_CONFIG.aiActive;

// Build dynamic text
let widgetText = 'Chat with our team';
if (widgetTrade && widgetGoal) {
  widgetText = `Chat about your ${widgetTrade} ${widgetGoal}`;
} else if (widgetTrade) {
  widgetText = `Chat about your ${widgetTrade} business`;
}
---

<div class="widget-jaina" id="widget-jaina" data-widget>
  <!-- Collapsed: Receptionist headshot with pulsing ring -->
  <button
    class="widget-jaina__trigger"
    id="widget-trigger"
    aria-label="Chat with us"
    aria-expanded="false"
    aria-haspopup="dialog"
  >
    <div class="widget-jaina__avatar">
      <img
        src="/assets/images/jaina-headshot.png"
        alt="Your AI receptionist"
        class="widget-jaina__avatar-img"
        loading="lazy"
        decoding="async"
      />
    </div>
    <span class="widget-jaina__pulse"></span>
    <span class="widget-jaina__pulse widget-jaina__pulse--delayed"></span>
  </button>

  <!-- Expanded: Panel -->
  <div class="widget-jaina__panel" id="widget-panel" role="dialog" aria-label="Chat widget" aria-hidden="true">
    <button class="widget-jaina__close" id="widget-close" aria-label="Close chat widget">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>

    <div class="widget-jaina__panel-avatar">
      <img
        src="/assets/images/jaina-headshot.png"
        alt="Your AI receptionist"
        class="widget-jaina__panel-avatar-img"
      />
    </div>

    <p class="widget-jaina__panel-greeting">Got questions? 👋</p>
    <p class="widget-jaina__panel-text">{widgetText}</p>

    <div class="widget-jaina__panel-actions">
      <button type="button" class="widget-jaina__panel-btn widget-jaina__panel-btn--chat" id="widget-chat-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/></svg>
        Chat with us
      </button>
      <button type="button" class="widget-jaina__panel-btn widget-jaina__panel-btn--call" id="widget-call-btn">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
        Call us
      </button>
    </div>
  </div>

  <!-- Widget Chat Popup -->
  <div class="jaina-popup" id="widget-chat-popup" aria-hidden="true">
    <div class="jaina-popup__overlay" data-close-widget-popup></div>
    <div class="jaina-popup__content">
      <button class="jaina-popup__close" data-close-widget-popup aria-label="Close">&times;</button>
      <div class="jaina-popup__avatar-small">
        <img src="/assets/images/jaina-headshot.png" alt="Your AI receptionist" class="jaina-popup__avatar-small-img" />
      </div>
      {aiActive ? (
        <Fragment>
          <p class="jaina-popup__title">Chat with us</p>
          <p class="jaina-popup__text">Our chat is being set up and will be live soon. In the meantime, get started with a quick call with Jeff.</p>
          <a href="/get-started" class="jaina-popup__btn">Get Started →</a>
        </Fragment>
      ) : (
        <Fragment>
          <p class="jaina-popup__title">Contact Jeff</p>
          <p class="jaina-popup__text">Contact Jeff for a quick demo. No obligation, no hard sell.</p>
          <a href="/get-started" class="jaina-popup__btn">Contact Jeff →</a>
        </Fragment>
      )}
    </div>
  </div>

  <!-- Widget Call Popup -->
  <div class="jaina-popup" id="widget-call-popup" aria-hidden="true">
    <div class="jaina-popup__overlay" data-close-widget-popup></div>
    <div class="jaina-popup__content">
      <button class="jaina-popup__close" data-close-widget-popup aria-label="Close">&times;</button>
      <div class="jaina-popup__avatar-small">
        <img src="/assets/images/jaina-headshot.png" alt="Your AI receptionist" class="jaina-popup__avatar-small-img" />
      </div>
      {aiActive ? (
        <Fragment>
          <p class="jaina-popup__title">Call us</p>
          <p class="jaina-popup__text">Our voice line is being configured and will be live soon. In the meantime, get started with a quick call with Jeff.</p>
          <a href="/get-started" class="jaina-popup__btn">Get Started →</a>
        </Fragment>
      ) : (
        <Fragment>
          <p class="jaina-popup__title">Contact Jeff</p>
          <p class="jaina-popup__text">Contact Jeff for a quick demo. No obligation, no hard sell.</p>
          <a href="/get-started" class="jaina-popup__btn">Contact Jeff →</a>
        </Fragment>
      )}
    </div>
  </div>
</div>

<style>
  .widget-jaina {
    position: fixed;
    bottom: 1.5rem;
    right: 1.5rem;
    z-index: 40;
    transition: opacity 300ms ease;
  }

  .widget-jaina.hidden {
    opacity: 0;
    pointer-events: none;
  }

  /* Trigger — receptionist headshot */
  .widget-jaina__trigger {
    position: relative;
    width: 64px;
    height: 64px;
    border-radius: 50%;
    background: transparent;
    border: 3px solid var(--color-accent);
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0;
    transition: transform 200ms, box-shadow 200ms;
    box-shadow: 0 4px 20px rgba(232, 145, 58, 0.35);
  }

  .widget-jaina__trigger:hover {
    transform: scale(1.1);
    box-shadow: 0 6px 28px rgba(232, 145, 58, 0.5);
  }

  @media (min-width: 768px) {
    .widget-jaina__trigger {
      width: 72px;
      height: 72px;
    }
  }

  .widget-jaina__avatar {
    width: 100%;
    height: 100%;
    border-radius: 50%;
    overflow: hidden;
  }

  .widget-jaina__avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
    border-radius: 50%;
  }

  /* Pulsing orange ring */
  .widget-jaina__pulse {
    position: absolute;
    inset: -6px;
    border-radius: 50%;
    border: 2.5px solid var(--color-accent);
    animation: widget-pulse-ring 3s ease-in-out infinite;
    pointer-events: none;
  }

  .widget-jaina__pulse--delayed {
    animation-delay: 1.25s;
  }

  @keyframes widget-pulse-ring {
    0% {
      opacity: 0.2;
    }
    50% {
      opacity: 0.8;
    }
    100% {
      opacity: 0.2;
    }
  }

  /* Panel */
  .widget-jaina__panel {
    position: absolute;
    bottom: calc(100% + 0.75rem);
    right: 0;
    width: 280px;
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 1rem;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.5);
    opacity: 0;
    visibility: hidden;
    transform: scale(0.9) translateY(8px);
    transform-origin: bottom right;
    transition: opacity 200ms, transform 200ms, visibility 200ms;
  }

  .widget-jaina__panel.open {
    opacity: 1;
    visibility: visible;
    transform: scale(1) translateY(0);
  }

  /* Close */
  .widget-jaina__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 32px;
    height: 32px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--color-text-muted);
    cursor: pointer;
    border-radius: 0.375rem;
    transition: color 150ms, background 150ms;
  }

  .widget-jaina__close:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  /* Panel Avatar — headshot */
  .widget-jaina__panel-avatar {
    width: 60px;
    height: 60px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--color-accent);
    margin: 0 auto 0.75rem;
  }

  .widget-jaina__panel-avatar-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .widget-jaina__panel-greeting {
    text-align: center;
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }

  .widget-jaina__panel-text {
    text-align: center;
    font-size: 0.875rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
    line-height: 1.4;
  }

  /* Panel Actions */
  .widget-jaina__panel-actions {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .widget-jaina__panel-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    padding: 0.625rem;
    font-size: 0.875rem;
    font-weight: 600;
    border-radius: 0.625rem;
    text-decoration: none;
    transition: all 150ms;
    min-height: 44px;
    cursor: pointer;
    font-family: inherit;
  }

  .widget-jaina__panel-btn--chat {
    background: var(--color-accent);
    color: #fff;
    border: none;
  }

  .widget-jaina__panel-btn--chat:hover {
    background: var(--color-accent-hover);
    color: #fff;
  }

  .widget-jaina__panel-btn--call {
    background: transparent;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border-subtle);
  }

  .widget-jaina__panel-btn--call:hover {
    border-color: var(--color-text-muted);
    color: var(--color-text-primary);
  }

  /* Placeholder Popups */
  .jaina-popup {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 100;
    align-items: center;
    justify-content: center;
  }

  .jaina-popup.active {
    display: flex;
  }

  .jaina-popup__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.6);
    backdrop-filter: blur(4px);
  }

  .jaina-popup__content {
    position: relative;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 1.25rem;
    padding: 2.5rem 2rem;
    max-width: 380px;
    width: 90%;
    text-align: center;
    box-shadow: 0 24px 80px rgba(0, 0, 0, 0.5);
  }

  .jaina-popup__close {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    color: var(--color-text-muted);
    font-size: 1.5rem;
    cursor: pointer;
    border-radius: 0.5rem;
    transition: color 150ms, background 150ms;
  }

  .jaina-popup__close:hover {
    color: var(--color-text-primary);
    background: rgba(255, 255, 255, 0.05);
  }

  .jaina-popup__avatar-small {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    overflow: hidden;
    border: 2px solid var(--color-accent);
    margin: 0 auto 1rem;
  }

  .jaina-popup__avatar-small-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center top;
  }

  .jaina-popup__title {
    font-size: 1.25rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .jaina-popup__text {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 1.5rem;
  }

  .jaina-popup__btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    background: var(--color-accent);
    color: #fff;
    font-weight: 700;
    font-size: 0.95rem;
    border-radius: 0.75rem;
    text-decoration: none;
    transition: background 150ms, transform 150ms;
    min-width: 160px;
  }

  .jaina-popup__btn:hover {
    background: var(--color-accent-hover);
    color: #fff;
    transform: scale(1.02);
  }
</style>

<script>
  // Widget expand/collapse
  const trigger = document.getElementById('widget-trigger');
  const panel = document.getElementById('widget-panel');
  const closeBtn = document.getElementById('widget-close');
  const widget = document.getElementById('widget-jaina');

  function openPanel() {
    panel?.classList.add('open');
    panel?.setAttribute('aria-hidden', 'false');
    trigger?.setAttribute('aria-expanded', 'true');
  }

  function closePanel() {
    panel?.classList.remove('open');
    panel?.setAttribute('aria-hidden', 'true');
    trigger?.setAttribute('aria-expanded', 'false');
  }

  trigger?.addEventListener('click', () => {
    if (panel?.classList.contains('open')) {
      closePanel();
    } else {
      openPanel();
    }
  });

  closeBtn?.addEventListener('click', closePanel);

  // Close on outside click
  document.addEventListener('click', (e) => {
    if (widget && !widget.contains(e.target as Node)) {
      closePanel();
    }
  });

  // Escape key closes panel
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') closePanel();
  });

  // Hero / Widget Intersection Observer
  const heroSection = document.getElementById('hero-jaina-section');
  if (heroSection && widget) {
    const observer = new IntersectionObserver(
      (entries) => {
        entries.forEach(entry => {
          if (entry.isIntersecting) {
            widget.classList.add('hidden');
            closePanel();
          } else {
            widget.classList.remove('hidden');
          }
        });
      },
      { threshold: 0.1 }
    );
    observer.observe(heroSection);
  }

  // Widget popup buttons
  const widgetChatBtn = document.getElementById('widget-chat-btn');
  const widgetCallBtn = document.getElementById('widget-call-btn');
  const widgetChatPopup = document.getElementById('widget-chat-popup');
  const widgetCallPopup = document.getElementById('widget-call-popup');

  function openWidgetPopup(popup: HTMLElement | null) {
    popup?.classList.add('active');
    popup?.setAttribute('aria-hidden', 'false');
    closePanel();
  }

  function closeWidgetPopup(popup: HTMLElement | null) {
    popup?.classList.remove('active');
    popup?.setAttribute('aria-hidden', 'true');
  }

  widgetChatBtn?.addEventListener('click', () => openWidgetPopup(widgetChatPopup));
  widgetCallBtn?.addEventListener('click', () => openWidgetPopup(widgetCallPopup));

  // Close widget popup buttons
  document.querySelectorAll('[data-close-widget-popup]').forEach(btn => {
    btn.addEventListener('click', (e) => {
      const popup = (e.currentTarget as HTMLElement).closest('.jaina-popup');
      closeWidgetPopup(popup as HTMLElement);
    });
  });
</script>
