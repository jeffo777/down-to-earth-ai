---
/**
 * GuaranteeBadge.astro — Trust badge with shield icon
 */
interface Props {
  guaranteeText?: string;
}

const { guaranteeText = '30 Day Money Back Guarantee' } = Astro.props;
---

<div class="guarantee-badge">
  <svg class="guarantee-badge__icon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
    <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
    <polyline points="9 12 11 14 15 10"/>
  </svg>
  <span>{guaranteeText}</span>
</div>

<style>
  .guarantee-badge {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-trust);
    font-size: 0.875rem;
    font-weight: 500;
  }

  .guarantee-badge__icon {
    flex-shrink: 0;
  }
</style>
