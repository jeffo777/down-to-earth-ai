---
/**
 * SchemaOrg.astro — Generates JSON-LD structured data for SEO & AI discoverability
 * Supports: Organization, Person (Founder), WebSite, Service, BreadcrumbList, Article
 * All entities are cross-linked via @id anchors to form a traversable knowledge graph.
 * Usage: Add to <head> in each layout, passing relevant props.
 */

interface BreadcrumbItem {
  name: string;
  url: string;
}

interface Props {
  // Page basics
  pageTitle: string;
  pageDescription: string;
  pageUrl?: string;
  // Schema types to include
  type: 'homepage' | 'service' | 'article' | 'core';
  // Service schema
  serviceName?: string;
  serviceDescription?: string;
  price?: string;        // e.g. "45" — injected from pricing.json via layouts
  audience?: string;     // e.g. "Plumbers"
  parentService?: string; // e.g. "AI Receptionist for Tradesmen"
  parentServiceUrl?: string;
  // Breadcrumbs
  breadcrumbs?: BreadcrumbItem[];
  // Article schema
  articleDate?: string;
  articleAuthor?: string;
}

const {
  pageTitle,
  pageDescription,
  pageUrl,
  type,
  serviceName,
  serviceDescription,
  price,
  audience,
  parentService,
  parentServiceUrl,
  breadcrumbs,
  articleDate,
  articleAuthor,
} = Astro.props;

const SITE_URL = 'https://downtoearthai.co.uk';
const fullUrl = pageUrl || SITE_URL;

// 1. Organization — always present, linked to founder via @id
const orgSchema = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  '@id': `${SITE_URL}/#organization`,
  name: 'Down To Earth AI',
  url: SITE_URL,
  description: 'Done-for-you AI receptionist and lead generation service built specifically for UK tradesmen. Not software — we handle all setup, configuration, and ongoing maintenance. 30-day full money-back guarantee including setup fee.',
  slogan: 'AI That Works As Hard As You Do',
  foundingLocation: {
    '@type': 'Place',
    name: 'Bournemouth, United Kingdom',
  },
  areaServed: {
    '@type': 'Country',
    name: 'United Kingdom',
  },
  founder: { '@id': `${SITE_URL}/#founder` },
  knowsAbout: [
    'AI receptionist for tradesmen',
    'Generative AI for small businesses',
    'Lead generation for UK trades',
    'AI phone answering',
    'AI marketing automation',
    'Custom AI automations for tradesmen',
  ],
  contactPoint: {
    '@type': 'ContactPoint',
    contactType: 'sales',
    url: `${SITE_URL}/get-started`,
    availableLanguage: 'English',
  },
  sameAs: ['https://www.linkedin.com/in/jeff-morton-contractor-leads/'],
};

// 2. Person (Founder) — always present, anchored with @id
const founderSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  '@id': `${SITE_URL}/#founder`,
  name: 'Jeff Morton',
  jobTitle: 'Founder',
  description: 'Tradesman with 25 years of experience in landscape gardening, building maintenance, and tree surgery. Qualified tree surgeon. Built Down To Earth AI to help UK tradesmen never miss another lead.',
  worksFor: { '@id': `${SITE_URL}/#organization` },
  url: 'https://www.linkedin.com/in/jeff-morton-contractor-leads/',
  sameAs: ['https://www.linkedin.com/in/jeff-morton-contractor-leads/'],
  knowsAbout: [
    'Trade businesses',
    'AI for small businesses',
    'Lead generation',
    'Landscape gardening',
    'Building maintenance',
    'Tree surgery',
  ],
};

// 3. WebSite — homepage only, linked to publisher org
const websiteSchema = type === 'homepage' ? {
  '@context': 'https://schema.org',
  '@type': 'WebSite',
  '@id': `${SITE_URL}/#website`,
  name: 'Down To Earth AI',
  url: SITE_URL,
  description: pageDescription,
  publisher: { '@id': `${SITE_URL}/#organization` },
  inLanguage: 'en-GB',
} : null;

// 4. Service — service pages, with @id and linked to org and parent service
const serviceSchema = (type === 'service' && serviceName) ? (() => {
  // Create a URL-safe slug for the service @id
  const serviceSlug = serviceName.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
  const schema: Record<string, any> = {
    '@context': 'https://schema.org',
    '@type': 'Service',
    '@id': `${SITE_URL}/#service-${serviceSlug}`,
    name: serviceName,
    description: serviceDescription || pageDescription,
    provider: { '@id': `${SITE_URL}/#organization` },
    areaServed: {
      '@type': 'Country',
      name: 'United Kingdom',
    },
    serviceType: 'AI Business Automation',
  };

  if (audience) {
    schema.audience = {
      '@type': 'Audience',
      audienceType: audience,
    };
  }

  if (price) {
    schema.offers = {
      '@type': 'Offer',
      price: price,
      priceCurrency: 'GBP',
      priceSpecification: {
        '@type': 'UnitPriceSpecification',
        price: price,
        priceCurrency: 'GBP',
        billingDuration: 'P1M',
        unitText: 'month',
      },
      availability: 'https://schema.org/InStock',
      url: `${SITE_URL}/get-started`,
    };
  }

  if (parentService && parentServiceUrl) {
    const parentSlug = parentService.toLowerCase().replace(/[^a-z0-9]+/g, '-').replace(/(^-|-$)/g, '');
    schema.isRelatedTo = {
      '@type': 'Service',
      '@id': `${SITE_URL}/#service-${parentSlug}`,
      name: parentService,
      url: parentServiceUrl.startsWith('http') ? parentServiceUrl : `${SITE_URL}${parentServiceUrl}`,
    };
  }

  return schema;
})() : null;

// 5. BreadcrumbList — service and article pages
const breadcrumbSchema = (breadcrumbs && breadcrumbs.length > 0) ? {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: breadcrumbs.map((item, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    name: item.name,
    item: item.url.startsWith('http') ? item.url : `${SITE_URL}${item.url}`,
  })),
} : null;

// 6. Article — blog posts, linked to founder via @id
const articleSchema = (type === 'article') ? {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: pageTitle,
  description: pageDescription,
  url: fullUrl,
  datePublished: articleDate || new Date().toISOString().split('T')[0],
  author: { '@id': `${SITE_URL}/#founder` },
  publisher: { '@id': `${SITE_URL}/#organization` },
  inLanguage: 'en-GB',
} : null;

// Collect all schemas
const schemas = [orgSchema, founderSchema, websiteSchema, serviceSchema, breadcrumbSchema, articleSchema].filter(Boolean);
---

{schemas.map(schema => (
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />
))}
