---
import CorePageLayout from '../layouts/CorePageLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import CTAButton from '../components/CTAButton.astro';

const frontmatter = {
  title: "FAQ",
  metaTitle: "AI For Tradesmen FAQ — £99/mo · No Contracts",
  metaDescription: "Common questions about AI for tradesmen. Pricing, setup, guarantees, and how everything works. Plain English, no tech-speak. £99/mo, no contracts.",
  canonicalUrl: "https://downtoearthai.co.uk/faq",
  showHeroAI: false,
  heroHeadline: "Frequently Asked Questions",
  heroSubhead: "Straight answers to the questions tradesmen ask us most.",
};

const generalFaqs = [
  { question: "What is Down To Earth AI?", answer: "We build AI tools specifically for UK tradesmen — plumbers, electricians, locksmiths, builders, and 10 other trades. Our flagship product Is your AI receptionist, an AI receptionist that answers your calls, texts, emails, and messages across 9 channels — 24/7. We also build lead generation websites, AI marketing tools, and custom business automations." },
  { question: "Who Is your AI receptionist?", answer: "Your AI receptionist. On phone calls and website chat, she has a real conversation — capturing lead details and offering to escalate urgent issues. On text-based channels like WhatsApp, email, Facebook, Instagram, and SMS, she sends one professional reply acknowledging the enquiry. Every lead is captured with contact details, job description, and urgency level — and delivered to you so you can follow up when you're ready." },
  { question: "Is this only for UK tradesmen?", answer: "Currently, yes. We've built everything — the language, the pricing, the trade knowledge — specifically for UK-based tradesmen. We understand the market, the regulations, and the way your customers communicate." },
  { question: "What trades do you support?", answer: "We support 13 trades: plumbers, electricians, locksmiths, gas engineers, drainage engineers, glaziers, roofers, HVAC engineers, alarm and security installers, pest control, garage door engineers, builders, and appliance repair engineers. Each trade gets a customised configuration." },
];

const pricingFaqs = [
  { question: "How much does it cost?", answer: "AI Receptionist: £299 setup + £99/month (includes 5 hours talk time, 20p/min after). Lead Gen Website: from £997 one-off. AI Marketing: £199 setup + £99/month. Custom Automations: bespoke pricing based on complexity. Every service comes with a 30-day money back guarantee." },
  { question: "Are there contracts?", answer: "No. Every service is pay-monthly with no minimum terms. Cancel anytime. No penalties, no notice period, no cancellation fees." },
  { question: "What's the 30-day guarantee?", answer: "If you're not happy within 30 days — for any reason — you get a full refund including the setup fee. No forms, no justification needed. We ask one question: why? And even that's optional." },
  { question: "Can I try before I buy?", answer: "You can book a free 15-minute demo where we show you your AI receptionist answering a call configured for your specific trade. And the 30-day guarantee means you're effectively trying it risk-free anyway." },
];

const technicalFaqs = [
  { question: "Do I need to install anything?", answer: "No. Your AI receptionist works with your existing phone number. No new equipment, no apps, no software. We handle all the technical setup during onboarding. All you do is tell us about your business." },
  { question: "How quickly can I get set up?", answer: "Most tradesmen are live within 24 hours. Some are ready the same day. It depends on how quickly we can get your business details — then our team handles everything else." },
  { question: "What happens if my internet goes down?", answer: "your AI receptionist runs in the cloud — she doesn't depend on your internet connection. Even if your Wi-Fi goes down, she keeps answering calls and messages. Your leads are never interrupted." },
  { question: "Is my data safe?", answer: "Yes. All data is encrypted, we comply with UK GDPR, and your customer data is never shared with third parties. We take data protection seriously because your reputation depends on it." },
  { question: "Can your AI receptionist handle emergencies differently?", answer: "Yes. Your AI receptionist recognises urgency language — 'burst pipe', 'locked out', 'no heating', 'gas smell'. Urgent enquiries are escalated immediately: your phone rings first. If you don't answer, the lead is routed to a professional human receptionist at Down To Earth AI who calls the customer directly." },
];
---

<CorePageLayout frontmatter={frontmatter}>

  <section>
    <div class="core-container">
      <h2 style="text-align: center; margin-bottom: 1.5rem;">General</h2>
      <FAQAccordion faqs={generalFaqs} />
    </div>
  </section>

  <section class="core-section--alt">
    <div class="core-container">
      <h2 style="text-align: center; margin-bottom: 1.5rem;">Pricing & Billing</h2>
      <FAQAccordion faqs={pricingFaqs} />
    </div>
  </section>

  <section>
    <div class="core-container">
      <h2 style="text-align: center; margin-bottom: 1.5rem;">Technical & Setup</h2>
      <FAQAccordion faqs={technicalFaqs} />
    </div>
  </section>

  <section class="core-section--alt" style="text-align: center;">
    <div class="core-container--narrow">
      <h2 style="margin-bottom: 0.75rem;">Still Got Questions?</h2>
      <p style="color: var(--color-text-secondary); margin-bottom: 1.5rem;">Chat with us in the bottom right, or Get Started and ask us anything.</p>
      <CTAButton buttonText="Get Started" buttonLink="/get-started" size="large" />
    </div>
  </section>

</CorePageLayout>
