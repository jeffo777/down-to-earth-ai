---
import CorePageLayout from '../layouts/CorePageLayout.astro';

const frontmatter = {
  title: "Terms of Service",
  metaTitle: "Terms of Service — Down To Earth AI",
  metaDescription: "Terms and conditions for using Down To Earth AI services. Plain English, no legal jargon where possible. Last updated March 2026.",
  canonicalUrl: "https://downtoearthai.co.uk/terms-of-service",
  showHeroAI: false,
  heroHeadline: "Terms of Service",
  heroSubhead: "Last updated: March 2026",
};
---

<CorePageLayout frontmatter={frontmatter}>
  <section>
    <div class="legal-content">
      <h2>1. Agreement</h2>
      <p>By using the Down To Earth AI website and services, you agree to these Terms of Service. If you don't agree, please don't use our services. We've tried to keep this document as straightforward as possible — no legal jargon where we can avoid it.</p>

      <h2>2. Our Services</h2>
      <p>Down To Earth AI provides AI-powered tools for tradesmen, including:</p>
      <ul>
        <li>AI Receptionist (your AI receptionist) — automated call answering and lead capture</li>
        <li>Lead Generation Websites — custom-built websites optimised for search engines</li>
        <li>AI Marketing — automated content creation from job photos</li>
        <li>Custom AI Automations — bespoke business workflow automation</li>
      </ul>

      <h2>3. Accounts & Registration</h2>
      <p>When you sign up for our services, you agree to provide accurate, complete information and to keep it up to date. You're responsible for maintaining the security of your account and for all activities that occur under it.</p>

      <h2>4. Pricing & Payment</h2>
