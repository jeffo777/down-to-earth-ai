---
import CorePageLayout from '../layouts/CorePageLayout.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const frontmatter = {
  title: "Contact Us — Down To Earth AI",
  metaTitle: "Contact Us | Down To Earth AI — Chat AI With Jeff, No Tech-Speak Required",
  metaDescription: "Get in touch with Down To Earth AI. Call Jeff on 01202 798159, email jeff@downtoearthai.co.uk, or send us a message. No tech-speak, no hard sell.",
  canonicalUrl: "https://downtoearthai.co.uk/contact",
  showHeroAI: false,
  heroHeadline: "Contact Us",
  heroSubhead: "Got a question? Send us a message or give Jeff a call.",
  widgetTrade: '',
  widgetGoal: '',
};

const contactFaqs = [
  {
    question: "Do I need to have a plan before contacting you?",
    answer: "Not at all. Many tradesmen come to us with just a vague sense that they're losing work or that things could run smoother. Jeff will help you identify the 'low hanging fruit' — the quick wins that save time, cut costs, and bring in more leads. You don't need a plan; that's what we're here for."
  },
  {
    question: "Will I understand the technology?",
    answer: "Yes. Jeff's passionate about breaking down tech talk into human talk. He's been where you are — running a trade business and needing practical answers, not jargon. Every conversation is plain English, no tech-speak required."
  },
  {
    question: "Can I just ask a question without committing to anything?",
    answer: "Absolutely. Use the form, give Jeff a call, or send an email. There's zero obligation. We'd rather have an honest conversation and tell you AI isn't right for you than sell you something you don't need."
  },
  {
    question: "What areas do you cover?",
    answer: "We work with tradesmen across the entire UK. Everything is set up and managed remotely — your AI receptionist works with your existing phone number, your website is built remotely, and all support is online or by phone."
  },
  {
    question: "How quickly will I hear back?",
    answer: "Typically within a few hours during business hours. If you use the chat widget, your AI receptionist responds instantly. For emails and form submissions, Jeff personally replies within 24 hours."
  },
];
---

<CorePageLayout frontmatter={frontmatter}>

  <section>
    <div class="core-container core-container--narrow">

      <p style="color: var(--color-text-secondary); line-height: 1.8; margin-bottom: 2.5rem; font-size: 1.0625rem;">Got a question about AI for your trade business? Whether you've got a specific goal in mind or you're just getting your bearings, Jeff's here to help. No tech-speak, no hard sell — just a straight conversation about where AI can make your life easier. Let's zero in on the easy wins first.</p>

      <div class="contact-grid">

        <!-- Form -->
        <div class="contact-form-wrap">
          <!-- TODO: Connect to GHL form/webhook -->
          <form class="contact-form" action="/thank-you" method="GET">
            <div class="form-field">
              <label for="contact-name">Name <span class="required">*</span></label>
              <input type="text" id="contact-name" name="name" required placeholder="Your name" />
            </div>

            <div class="form-field">
              <label for="contact-email">Email <span class="required">*</span></label>
              <input type="email" id="contact-email" name="email" required placeholder="your@email.co.uk" />
            </div>

            <div class="form-field">
              <label for="contact-phone">Phone <span class="optional">(optional)</span></label>
              <input type="tel" id="contact-phone" name="phone" placeholder="07xxx xxx xxx" />
            </div>

            <div class="form-field">
              <label for="contact-message">Message <span class="required">*</span></label>
              <textarea id="contact-message" name="message" required placeholder="Tell us about your business or ask a question..." rows="5"></textarea>
            </div>

            <button type="submit" class="contact-submit">Send Message</button>
          </form>
        </div>

        <!-- Contact Details -->
        <div class="contact-details">
          <div class="contact-details__card">
            <h3>Call Jeff</h3>
            <a href="tel:01202798159" class="contact-details__phone">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
              01202 798159
            </a>
          </div>

          <div class="contact-details__card">
            <h3>Email</h3>
            <a href="mailto:jeff@downtoearthai.co.uk" class="contact-details__email">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
              jeff@downtoearthai.co.uk
            </a>
          </div>

          <div class="contact-details__card">
            <h3>Prefer To Chat?</h3>
            <p>Book a free 15-minute call with Jeff. No obligation.</p>
            <a href="/get-started" class="contact-details__cta">Book A Call →</a>
          </div>
        </div>

      </div>
    </div>
  </section>

  <section class="core-section--alt">
    <div class="core-container">
      <h2 style="text-align: center; margin-bottom: 1.5rem;">Common Questions</h2>
      <FAQAccordion faqs={contactFaqs} />
    </div>
  </section>

</CorePageLayout>

<style>
  .contact-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 3rem;
  }
  @media (min-width: 768px) {
    .contact-grid {
      grid-template-columns: 3fr 2fr;
      gap: 4rem;
    }
  }

  .required { color: var(--color-accent); }
  .optional { color: var(--color-text-muted); font-weight: 400; font-size: 0.8rem; }

  .contact-submit {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    padding: 0.75rem 1.5rem;
    min-width: 180px;
    min-height: 44px;
    background: var(--color-accent);
    color: #fff;
    font-weight: 700;
    font-size: 1rem;
    border-radius: 0.75rem;
    border: none;
    cursor: pointer;
    transition: background 150ms, transform 150ms, box-shadow 150ms;
    font-family: inherit;
  }
  .contact-submit:hover {
    background: var(--color-accent-hover);
    transform: scale(1.02);
    box-shadow: 0 4px 20px rgba(232, 145, 58, 0.25);
  }
  .contact-submit:focus-visible {
    outline: 2px solid var(--color-accent);
    outline-offset: 2px;
  }

  .contact-details {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .contact-details__card {
    padding: 1.5rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 1rem;
  }

  .contact-details__card h3 {
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .contact-details__card p {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin-bottom: 0.75rem;
  }

  .contact-details__phone,
  .contact-details__email {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: var(--color-accent);
    font-weight: 600;
    font-size: 1rem;
    text-decoration: none;
    transition: color 150ms;
  }
  .contact-details__phone:hover,
  .contact-details__email:hover {
    color: var(--color-accent-hover);
  }

  .contact-details__cta {
    display: inline-block;
    color: var(--color-accent);
    font-weight: 600;
    text-decoration: none;
    transition: color 150ms;
  }
  .contact-details__cta:hover {
    color: var(--color-accent-hover);
  }
</style>
