---
import CorePageLayout from '../layouts/CorePageLayout.astro';

const frontmatter = {
  title: "Thank You — Down To Earth AI",
  metaTitle: "Thank You | Down To Earth AI",
  metaDescription: "Thanks for getting in touch. We'll get back to you shortly.",
  canonicalUrl: "https://downtoearthai.co.uk/thank-you",
  showHeroAI: false,
  heroHeadline: "Thank You!",
  heroSubhead: "Your message has been sent. We'll get back to you shortly.",
  widgetTrade: '',
  widgetGoal: '',
};
---

<CorePageLayout frontmatter={frontmatter}>

  <section>
    <div class="core-container core-container--narrow" style="text-align: center;">
      <div class="ty-icon">
        <svg width="64" height="64" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-accent);">
          <polyline points="20 6 9 17 4 12"/>
        </svg>
      </div>
      <h2>We've Got Your Message</h2>
      <p style="color: var(--color-text-secondary); font-size: 1.0625rem; line-height: 1.7; margin-bottom: 2rem;">
        Jeff will get back to you within 24 hours. If it's urgent, call us on
        <a href="tel:01onal202798159" style="color: var(--color-accent); text-decoration: none; font-weight: 600;">01onal202 798159</a>.
      </p>
      <a href="/" style="color: var(--color-accent); font-weight: 600; text-decoration: none;">← Back to Home</a>
    </div>
  </section>

</CorePageLayout>

<style>
  .ty-icon {
    width: 80px;
    height: 80px;
    border-radius: 50%;
    background: rgba(232, 145, 58, 0.1);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }
</style>
