---
import CorePageLayout from '../layouts/CorePageLayout.astro';
import GuaranteeBadge from '../components/GuaranteeBadge.astro';


const frontmatter = {
  title: "Get Started — Down To Earth AI",
  metaTitle: "Get Started — Contact Jeff | Down To Earth AI",
  metaDescription: "Get in touch with Jeff. No obligation. No hard sell. He'll learn about your business and explain how everything works for your trade.",
  canonicalUrl: "https://downtoearthai.co.uk/get-started",
  showHeroAI: false,
  heroAIText: "Learn about your business",
  heroHeadline: "Let's Get You Set Up",
  heroSubhead: "Get in touch with Jeff. No obligation. No hard sell.",
  widgetTrade: '',
  widgetGoal: 'getting started',
};
---

<CorePageLayout frontmatter={frontmatter}>

  <!-- What Happens -->
  <section class="core-section--alt">
    <div class="core-container core-container--narrow" style="text-align: center;">
      <h2>What Happens Next</h2>
      <p style="color: var(--color-text-secondary); font-size: 1.0625rem; line-height: 1.7; margin-bottom: 2rem;">
        Jeff's spent 25 years in the trades. He knows what it's like. Send him a message and he'll get back to you to learn about your business, explain how everything works for your specific trade, and if it's right for you, get you set up.
      </p>
      <div class="gs-steps">
        <div class="gs-step">
          <div class="gs-step__num">1</div>
          <h3>Jeff learns about your business</h3>
          <p>Your trade, your area, your goals.</p>
        </div>
        <div class="gs-step">
          <div class="gs-step__num">2</div>
          <h3>He explains how it works for your trade</h3>
          <p>Tailored to exactly what you do.</p>
        </div>
        <div class="gs-step">
          <div class="gs-step__num">3</div>
          <h3>If it's right for you, he gets you set up</h3>
          <p>No pressure. No hard sell.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form -->
  <section>
    <div class="core-container core-container--narrow" style="text-align: center;">
      <h2>Get In Touch With Jeff</h2>
      <p style="color: var(--color-text-secondary); margin-bottom: 2rem;">Drop Jeff a message and he'll get back to you within 24 hours. No obligation, no hard sell.</p>
      <form class="gs-contact-form" action="https://api.web3forms.com/submit" method="POST">
        <input type="hidden" name="access_key" value="82f978fd-7ee5-434d-ab2c-202b121d25fb" />
        <input type="hidden" name="subject" value="New enquiry from Down To Earth AI — Get Started" />
        <input type="hidden" name="redirect" value="https://downtoearthai.co.uk/thank-you" />
        <input type="checkbox" name="botcheck" class="hidden" style="display:none" />

        <div class="gs-form-group">
          <label for="gs-name" class="gs-label">Name <span class="gs-required">*</span></label>
          <input type="text" id="gs-name" name="name" required placeholder="Your name" class="gs-input" />
        </div>

        <div class="gs-form-group">
          <label for="gs-email" class="gs-label">Email address <span class="gs-required">*</span></label>
          <input type="email" id="gs-email" name="email" required placeholder="your@email.co.uk" class="gs-input" />
        </div>

        <div class="gs-form-group">
          <label for="gs-phone" class="gs-label">Phone number <span class="gs-optional">(optional)</span></label>
          <input type="tel" id="gs-phone" name="phone" placeholder="07xxx xxxxxx" class="gs-input" />
        </div>

        <div class="gs-form-group">
          <label for="gs-message" class="gs-label">Your message <span class="gs-required">*</span></label>
          <textarea id="gs-message" name="message" required rows="4" placeholder="Tell Jeff a bit about your trade and what you're looking for..." class="gs-textarea"></textarea>
        </div>

        <button type="submit" class="gs-submit-btn">
          Send Message →
        </button>
      </form>
    </div>
  </section>

  <!-- Trust -->
  <section class="core-section--alt">
    <div class="core-container core-container--narrow" style="text-align: center;">
      <GuaranteeBadge />
      <p style="color: var(--color-text-secondary); margin-top: 1rem; font-size: 0.9375rem;">30 Day Money Back Guarantee. No contracts. Cancel anytime.</p>
    </div>
  </section>

</CorePageLayout>

<style>
  .gs-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 2rem;
  }
  @media (min-width: 768px) { .gs-steps { grid-template-columns: repeat(3, 1fr); } }
  .gs-step {
    text-align: center;
    padding: 1.5rem;
    background: var(--color-surface);
    border-radius: 1rem;
    border: 1px solid var(--color-border-subtle);
  }
  .gs-step__num {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-weight: 800;
    font-size: 1.125rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }
  .gs-step h3 { margin-bottom: 0.5rem; font-size: 1.0625rem; }
  .gs-step p { color: var(--color-text-secondary); font-size: 0.9375rem; }



  /* Contact Form */
  .gs-contact-form {
    max-width: 480px;
    margin: 0 auto;
    text-align: left;
  }

  .gs-form-group {
    margin-bottom: 1.25rem;
  }

  .gs-label {
    display: block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .gs-required {
    color: var(--color-accent);
  }

  .gs-optional {
    color: var(--color-text-muted);
    font-weight: 400;
    font-size: 0.8125rem;
  }

  .gs-input,
  .gs-textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-family: inherit;
    color: var(--color-text-primary);
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.75rem;
    transition: border-color 150ms, box-shadow 150ms;
  }

  .gs-input:focus,
  .gs-textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(232, 145, 58, 0.15);
  }

  .gs-input::placeholder,
  .gs-textarea::placeholder {
    color: var(--color-text-muted);
  }

  .gs-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .gs-submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.875rem 1.5rem;
    font-size: 1.0625rem;
    font-weight: 700;
    font-family: inherit;
    color: #fff;
    background: var(--color-accent);
    border: none;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: background 150ms, transform 150ms;
    margin-top: 0.5rem;
  }

  .gs-submit-btn:hover {
    background: var(--color-accent-hover);
    transform: scale(1.01);
  }
</style>

