---
import CorePageLayout from '../layouts/CorePageLayout.astro';
import GuaranteeBadge from '../components/GuaranteeBadge.astro';
import { SITE_CONFIG } from '../config/site.js';

const aiActive = SITE_CONFIG.aiActive;

const frontmatter = {
  title: "Get Started — Down To Earth AI",
  metaTitle: "Get Started — Contact Jeff | Down To Earth AI",
  metaDescription: "Get in touch with Jeff. No obligation. No hard sell. He'll learn about your business and explain how everything works for your trade.",
  canonicalUrl: "https://downtoearthai.co.uk/get-started",
  showHeroAI: true,
  heroAIText: "Learn about your business",
  heroHeadline: "Let's Get You Set Up",
  heroSubhead: "Get in touch with Jeff. No obligation. No hard sell.",
  widgetTrade: '',
  widgetGoal: 'getting started',
};
---

<CorePageLayout frontmatter={frontmatter}>

  <!-- What Happens -->
  <section class="core-section--alt">
    <div class="core-container core-container--narrow" style="text-align: center;">
      <h2>What Happens Next</h2>
      <p style="color: var(--color-text-secondary); font-size: 1.0625rem; line-height: 1.7; margin-bottom: 2rem;">
        Jeff's spent 25 years in the trades. He knows what it's like. Send him a message and he'll get back to you to learn about your business, explain how everything works for your specific trade, and if it's right for you, get you set up.
      </p>
      <div class="gs-steps">
        <div class="gs-step">
          <div class="gs-step__num">1</div>
          <h3>Jeff learns about your business</h3>
          <p>Your trade, your area, your goals.</p>
        </div>
        <div class="gs-step">
          <div class="gs-step__num">2</div>
          <h3>He explains how it works for your trade</h3>
          <p>Tailored to exactly what you do.</p>
        </div>
        <div class="gs-step">
          <div class="gs-step__num">3</div>
          <h3>If it's right for you, he gets you set up</h3>
          <p>No pressure. No hard sell.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Contact Form / Calendar -->
  <section>
    <div class="core-container core-container--narrow" style="text-align: center;">
      {aiActive ? (
        <Fragment>
          <!-- GHL Calendar (shown when AI is active) -->
          <h2>Book Your Call</h2>
          <p style="color: var(--color-text-secondary); margin-bottom: 2rem;">Choose a time that works for you. It only takes 15 minutes.</p>
          <div class="gs-booking-widget" id="booking-widget">
            <!-- TODO: Insert GHL calendar embed code here -->
            <div class="gs-booking-placeholder">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="color: var(--color-accent); margin-bottom: 1rem;">
                <rect x="3" y="4" width="18" height="18" rx="2" ry="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/>
              </svg>
              <p style="font-size: 1.125rem; font-weight: 700; color: var(--color-text-primary); margin-bottom: 0.5rem;">Calendar Loading...</p>
              <p style="color: var(--color-text-muted); font-size: 0.9rem;">The booking calendar will appear here.</p>
            </div>
          </div>
        </Fragment>
      ) : (
        <Fragment>
          <!-- Contact Form (shown when AI is not yet active) -->
          <h2>Contact Jeff</h2>
          <p style="color: var(--color-text-secondary); margin-bottom: 2rem;">Drop Jeff a message and he'll get back to you within 24 hours.</p>
          <form class="gs-contact-form" action="https://formsubmit.co/jeff@downtoearthai.co.uk" method="POST">
            <input type="hidden" name="_subject" value="New enquiry from Down To Earth AI website" />
            <input type="hidden" name="_captcha" value="true" />
            <input type="hidden" name="_next" value="https://downtoearthai.co.uk/thank-you" />
            <input type="text" name="_honey" style="display:none" />

            <div class="gs-form-group">
              <label for="contact-email" class="gs-label">Email address <span class="gs-required">*</span></label>
              <input type="email" id="contact-email" name="email" required placeholder="your@email.co.uk" class="gs-input" />
            </div>

            <div class="gs-form-group">
              <label for="contact-message" class="gs-label">Your message <span class="gs-required">*</span></label>
              <textarea id="contact-message" name="message" required rows="4" placeholder="Tell Jeff a bit about your trade and what you're looking for..." class="gs-textarea"></textarea>
            </div>

            <button type="submit" class="gs-submit-btn">
              Send Message →
            </button>
          </form>
        </Fragment>
      )}
    </div>
  </section>

  <!-- Trust -->
  <section class="core-section--alt">
    <div class="core-container core-container--narrow" style="text-align: center;">
      <GuaranteeBadge />
      <p style="color: var(--color-text-secondary); margin-top: 1rem; font-size: 0.9375rem;">30 Day Money Back Guarantee. No contracts. Cancel anytime.</p>
    </div>
  </section>

</CorePageLayout>

<style>
  .gs-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 1.5rem;
    margin-top: 2rem;
  }
  @media (min-width: 768px) { .gs-steps { grid-template-columns: repeat(3, 1fr); } }
  .gs-step {
    text-align: center;
    padding: 1.5rem;
    background: var(--color-surface);
    border-radius: 1rem;
    border: 1px solid var(--color-border-subtle);
  }
  .gs-step__num {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-weight: 800;
    font-size: 1.125rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }
  .gs-step h3 { margin-bottom: 0.5rem; font-size: 1.0625rem; }
  .gs-step p { color: var(--color-text-secondary); font-size: 0.9375rem; }

  /* Calendar placeholder (for aiActive = true) */
  .gs-booking-widget {
    min-height: 500px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .gs-booking-placeholder {
    width: 100%;
    min-height: 500px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: var(--color-surface);
    border: 2px dashed var(--color-border-subtle);
    border-radius: 1.5rem;
    padding: 2rem;
  }

  /* Contact Form */
  .gs-contact-form {
    max-width: 480px;
    margin: 0 auto;
    text-align: left;
  }

  .gs-form-group {
    margin-bottom: 1.25rem;
  }

  .gs-label {
    display: block;
    font-size: 0.9375rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .gs-required {
    color: var(--color-accent);
  }

  .gs-optional {
    color: var(--color-text-muted);
    font-weight: 400;
    font-size: 0.8125rem;
  }

  .gs-input,
  .gs-textarea {
    width: 100%;
    padding: 0.75rem 1rem;
    font-size: 1rem;
    font-family: inherit;
    color: var(--color-text-primary);
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.75rem;
    transition: border-color 150ms, box-shadow 150ms;
  }

  .gs-input:focus,
  .gs-textarea:focus {
    outline: none;
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(232, 145, 58, 0.15);
  }

  .gs-input::placeholder,
  .gs-textarea::placeholder {
    color: var(--color-text-muted);
  }

  .gs-textarea {
    resize: vertical;
    min-height: 120px;
  }

  .gs-submit-btn {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 100%;
    padding: 0.875rem 1.5rem;
    font-size: 1.0625rem;
    font-weight: 700;
    font-family: inherit;
    color: #fff;
    background: var(--color-accent);
    border: none;
    border-radius: 0.75rem;
    cursor: pointer;
    transition: background 150ms, transform 150ms;
    margin-top: 0.5rem;
  }

  .gs-submit-btn:hover {
    background: var(--color-accent-hover);
    transform: scale(1.01);
  }
</style>

