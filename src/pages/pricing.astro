---
import CorePageLayout from '../layouts/CorePageLayout.astro';
import CTAButton from '../components/CTAButton.astro';
import GuaranteeBadge from '../components/GuaranteeBadge.astro';
import FAQAccordion from '../components/FAQAccordion.astro';

const frontmatter = {
  title: "Pricing",
  metaTitle: "Pricing — AI For UK Tradesmen · £99/mo · No Contracts",
  metaDescription: "Clear, simple pricing for UK tradesmen. AI receptionist from £99/mo. No contracts, no hidden fees, 30-day money-back guarantee. Cancel anytime.",
  canonicalUrl: "https://downtoearthai.co.uk/pricing",
  showHeroAI: false,
  heroHeadline: "Simple Pricing. No Surprises.",
  heroSubhead: "No contracts. No hidden fees. No minimum terms. Every plan comes with a 30-day full money back guarantee.",
};

const pricingFaqs = [
  { question: "Are there any hidden fees?", answer: "No. The prices shown are the prices you pay. Setup fee, monthly fee, and any usage charges are clearly stated upfront. No surprises on your invoice, ever." },
  { question: "Do I have to sign a contract?", answer: "No. All our services are pay-monthly with no minimum terms. You can cancel anytime — no penalties, no notice period, no questions asked." },
  { question: "What's the 30-day guarantee?", answer: "If you're not satisfied within 30 days of signing up — for any reason — we refund every penny, including the setup fee. No forms, no justification needed. You just tell us and the money goes back." },
  { question: "Can I bundle services for a discount?", answer: "Yes. If you're using multiple services (say AI Receptionist plus a Lead Gen Website), we offer bundle pricing. Get in touch and we'll put together a package that makes sense for your business." },
  { question: "What counts towards the 5 hours talk time?", answer: "Only active call time. Hold time, ring time, and setup don't count. Most tradesmen never exceed 5 hours per month, but if you do, the overage rate is just 20p per minute." },
  { question: "Can I upgrade or downgrade anytime?", answer: "Yes. Moving between plans or adding services is instant. Downgrading takes effect at your next billing date. No penalties either way." },
];
---

<CorePageLayout frontmatter={frontmatter}>

  <!-- AI RECEPTIONIST -->
  <section>
    <div class="core-container">
      <div style="display: grid; grid-template-columns: 1fr; gap: 2rem; max-width: 60rem; margin: 0 auto;">

        <div class="pricing-card" style="border-color: var(--color-accent);">
          <div style="display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.5rem;">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="var(--color-accent)" stroke-width="2"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            <span style="font-size: 0.75rem; font-weight: 700; color: var(--color-accent); text-transform: uppercase; letter-spacing: 0.05em;">Most Popular</span>
          </div>
          <p class="pricing-card__name">AI Receptionist (your AI receptionist)</p>
          <p class="pricing-card__price">£99/month</p>
          <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-bottom: 1.25rem;">£299 one-off setup fee</p>
          <ul class="pricing-card__features">
            <li>9 channels covered (phone, SMS, WhatsApp, email, chat, social)</li>
            <li>5 hours talk time included per month</li>
            <li>20p per minute after that</li>
            <li>24/7 coverage — weekends, bank holidays, 3am</li>
            <li>Lead capture, qualification & instant delivery</li>
            <li>Human backup for complex situations</li>
            <li>Configured for your specific trade</li>
            <li>No contracts or minimum terms</li>
          </ul>
          <div style="display: flex; flex-direction: column; align-items: center; gap: 0.75rem;">
            <CTAButton buttonText="Get Started" buttonLink="/get-started" size="large" />
            <GuaranteeBadge />
          </div>
        </div>

        <div style="display: grid; grid-template-columns: 1fr; gap: 2rem;">
          <div style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 1.5rem;">

            <div class="pricing-card">
              <p class="pricing-card__name">Lead Gen Website</p>
              <p class="pricing-card__price">From £997</p>
              <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-bottom: 1.25rem;">One-off build</p>
              <ul class="pricing-card__features">
                <li>Custom design for your trade</li>
                <li>Local SEO optimisation</li>
                <li>Mobile-first, lightning-fast</li>
                <li>Google Business integration</li>
                <li>Conversion-focused layout</li>
                <li>You own everything</li>
              </ul>
              <div style="margin-top: auto;">
                <CTAButton buttonText="Learn More" buttonLink="/ai-lead-generation-websites-for-tradesmen" />
              </div>
            </div>

            <div class="pricing-card">
              <p class="pricing-card__name">AI Marketing</p>
              <p class="pricing-card__price">£99/month</p>
              <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-bottom: 1.25rem;">£199 one-off setup</p>
              <ul class="pricing-card__features">
                <li>Photo → blog post in minutes</li>
                <li>Social media content</li>
                <li>Google Business updates</li>
                <li>Review request automation</li>
                <li>Content calendar</li>
                <li>Local SEO boost</li>
              </ul>
              <div style="margin-top: auto;">
                <CTAButton buttonText="Learn More" buttonLink="/ai-marketing-for-tradesmen" />
              </div>
            </div>

            <div class="pricing-card">
              <p class="pricing-card__name">Custom Automations</p>
              <p class="pricing-card__price">Bespoke</p>
              <p style="color: var(--color-text-muted); font-size: 0.875rem; margin-bottom: 1.25rem;">Depends on complexity</p>
              <ul class="pricing-card__features">
                <li>Automated follow-ups</li>
                <li>Invoice & payment reminders</li>
                <li>Quote follow-up sequences</li>
                <li>Customer database</li>
                <li>Reporting & insights</li>
                <li>Integrates with your tools</li>
              </ul>
              <div style="margin-top: auto;">
                <CTAButton buttonText="Learn More" buttonLink="/custom-ai-automations-for-tradesmen" />
              </div>
            </div>

          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- GUARANTEE -->
  <section class="core-section--alt">
    <div class="core-container" style="text-align: center; max-width: 36rem; margin: 0 auto;">
      <h2 style="margin-bottom: 1rem;">30-Day Money Back Guarantee</h2>
      <p style="color: var(--color-text-secondary); line-height: 1.7;">Every service comes with a 30-day full money back guarantee. If it's not working for you — for any reason — you get a complete refund. Including the setup fee. No forms, no justification, no small print.</p>
      <div style="margin-top: 1.5rem; display: flex; justify-content: center;"><GuaranteeBadge /></div>
    </div>
  </section>

  <!-- FAQs -->
  <section>
    <div class="core-container">
      <h2 style="text-align: center; margin-bottom: 1.5rem;">Pricing Questions</h2>
      <FAQAccordion faqs={pricingFaqs} />
    </div>
  </section>

</CorePageLayout>

<style>
  @media (max-width: 767px) {
    div[style*="grid-template-columns: 1fr 1fr 1fr"] {
      grid-template-columns: 1fr !important;
    }
  }
</style>
