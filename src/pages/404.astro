---
import CorePageLayout from '../layouts/CorePageLayout.astro';
import CTAButton from '../components/CTAButton.astro';

const frontmatter = {
  title: "Page Not Found",
  metaTitle: "Page Not Found — Down To Earth AI",
  metaDescription: "Sorry, we couldn't find the page you were looking for.",
  showHeroAI: false,
  heroHeadline: "Page Not Found",
  heroSubhead: "The page you're looking for doesn't exist or has been moved.",
};
---

<CorePageLayout frontmatter={frontmatter}>
  <section style="text-align: center; min-height: 30vh; display: flex; align-items: center; justify-content: center;">
    <div class="core-container--narrow">
      <p style="font-size: 5rem; font-weight: 800; color: var(--color-accent); margin-bottom: 0.5rem; line-height: 1;">404</p>
      <p style="color: var(--color-text-secondary); margin-bottom: 2rem;">That page doesn't exist. But don't worry — our AI receptionist never goes missing.</p>
      <div style="display: flex; gap: 1rem; justify-content: center; flex-wrap: wrap;">
        <CTAButton buttonText="Go Home" buttonLink="/" />
        <CTAButton buttonText="Contact Us" buttonLink="/contact" />
      </div>
    </div>
  </section>
</CorePageLayout>
