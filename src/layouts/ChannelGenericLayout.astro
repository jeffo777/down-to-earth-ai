---
/**
 * ChannelGenericLayout.astro
 * Template for: Generic channel pages (11 pages)
 * e.g. /ai-phone-answering-for-tradesmen
 */
import '../styles/global.css';
import pricing from '../data/pricing.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import HeroJaina from '../components/HeroJaina.astro';
import WidgetJaina from '../components/WidgetJaina.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import SchemaOrg from '../components/SchemaOrg.astro';
import trades from '../data/trades.json';

interface Props {
  frontmatter: {
    title: string;
    metaTitle: string;
    metaDescription: string;
    canonicalUrl?: string;
    heroHeadline: string;
    heroSubhead: string;
    heroAIText: string;
    price?: string;
    channelSlug: string;
    channelName: string;
    // How It Works
    step1Title: string; step1Text: string;
    step2Title: string; step2Text: string;
    step3Title: string; step3Text: string;
    // Scenario
    scenario: string;
    // FAQs
    faqs: Array<{ question: string; answer: string }>;
    widgetTrade?: string;
    widgetGoal?: string;
  };
}

const { frontmatter } = Astro.props;
const fm = frontmatter;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fm.metaTitle}</title>
  <meta name="description" content={fm.metaDescription} />
  {fm.canonicalUrl && <link rel="canonical" href={fm.canonicalUrl} />}
  <meta property="og:title" content={fm.metaTitle} />
  <meta property="og:description" content={fm.metaDescription} />
  <meta property="og:url" content={fm.canonicalUrl} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <SchemaOrg
    type="service"
    pageTitle={fm.title}
    pageDescription={fm.metaDescription}
    pageUrl={fm.canonicalUrl}
    serviceName={fm.channelName + ' for Tradesmen'}
    serviceDescription={fm.metaDescription}
    price={String(pricing.receptionist.monthlyPrice)}
    breadcrumbs={[
      { name: 'Home', url: '/' },
      { name: 'AI Receptionist', url: '/ai-receptionist-for-tradesmen' },
      { name: fm.channelName, url: fm.canonicalUrl || '' },
    ]}
  />
</head>
<body>
  <Header />

  <main id="main-content" style="padding-top: 64px;">

    <!-- 1. HERO — Stacked -->
    <section class="cg-hero">
      <div class="cg-hero__inner">
        <div class="cg-hero__stacked">
          <h1>{fm.heroHeadline}</h1>
          <p class="cg-hero__subhead">{fm.heroSubhead}</p>          <div class="cg-hero__jaina">
            <HeroJaina showHeroAI={true} heroAIText={fm.heroAIText} />
          </div>

          <div class="cg-hero__trust-row">
            <span class="cg-hero__done-tag">✓ 100% done for you</span>
            <span class="cg-hero__done-tag">🇬🇧 UK business</span>
            <span class="cg-hero__price-tag">Only {pricing.receptionist.formatted.monthly}</span>
            <span class="cg-hero__guarantee-tag">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              30-day money back guarantee
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. HOW THIS CHANNEL WORKS -->
    <section class="cg-section cg-section--alt">
      <div class="cg-container">
        <h2 class="cg-section__title">How {fm.channelName} Works</h2>
        <div class="cg-steps">
          <div class="cg-step"><div class="cg-step__num">1</div><h3>{fm.step1Title}</h3><p>{fm.step1Text}</p></div>
          <div class="cg-step"><div class="cg-step__num">2</div><h3>{fm.step2Title}</h3><p>{fm.step2Text}</p></div>
          <div class="cg-step"><div class="cg-step__num">3</div><h3>{fm.step3Title}</h3><p>{fm.step3Text}</p></div>
        </div>
      </div>
    </section>

    <!-- 3. SCENARIO -->
    <section class="cg-section">
      <div class="cg-container cg-container--narrow">
        <h2 class="cg-section__title">Real Scenario</h2>
        <p class="cg-scenario">{fm.scenario}</p>
      </div>
    </section>

    <!-- 4. WHICH TRADES BENEFIT MOST -->
    <section class="cg-section cg-section--alt">
      <div class="cg-container">
        <h2 class="cg-section__title">{fm.channelName} For Your Trade</h2>
        <p class="cg-section__subtitle">See how {fm.channelName.toLowerCase()} works specifically for your trade.</p>
        <div class="cg-trades">
          {trades.map(trade => (
            <a href={`/${fm.channelSlug}-for-${trade.slug}`} class="cg-trade-link">
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              <span>{trade.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 5. FAQs -->
    {fm.faqs && fm.faqs.length > 0 && (
      <section class="cg-section">
        <div class="cg-container">
          <h2 class="cg-section__title">Frequently Asked Questions</h2>
          <FAQAccordion faqs={fm.faqs} />
        </div>
      </section>
    )}

    <!-- 6. CTA -->
    <section class="cg-section cg-section--alt" style="text-align: center;">
      <div class="cg-container cg-container--narrow">
        <h2>Ready To Get Started?</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: 1.5rem;">No risk. 30-day money back guarantee.</p>
        <CTAButton buttonText="Get Started" buttonLink="/get-started" showPrice={true} priceText={fm.price || pricing.receptionist.formatted.setupMonthly} showGuarantee={true} size="large" />
      </div>
    </section>

  </main>

  <Footer />
  <CookieConsent />
  <WidgetJaina widgetTrade={fm.widgetTrade || ''} widgetGoal={fm.widgetGoal || ''} />
</body>
</html>

<style>
  .cg-hero { background: var(--color-primary); padding: 3rem 1rem 2.5rem; }
  .cg-hero__inner { max-width: 72rem; margin: 0 auto; }
  .cg-hero__stacked { display: flex; flex-direction: column; align-items: center; text-align: center; }
  @media (min-width: 1024px) { .cg-hero { padding: 4rem 2rem 2.5rem; } }
  .cg-hero__subhead { font-size: 1.1rem; color: var(--color-text-secondary); margin-bottom: 1rem; max-width: 36rem; line-height: 1.6; }
  .cg-hero__trust-row { margin-top: 1.25rem; display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .cg-hero__price-tag { font-size: 1.05rem; font-weight: 700; color: var(--color-text-primary); }
  .cg-hero__done-tag { font-size: 0.95rem; font-weight: 600; color: var(--color-accent); }
  .cg-hero__guarantee-tag { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.9rem; font-weight: 600; color: var(--color-trust); }

  .cg-section { padding: 3rem 1rem; }
  @media (min-width: 768px) { .cg-section { padding: 5rem 2rem; } }
  .cg-section--alt { background: var(--color-secondary); }
  .cg-container { max-width: 72rem; margin: 0 auto; }
  .cg-container--narrow { max-width: 42rem; margin: 0 auto; }
  .cg-section__title { text-align: center; margin-bottom: 0.75rem; }
  .cg-section__subtitle { text-align: center; color: var(--color-text-muted); margin-bottom: 2rem; }

  .cg-steps { display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin-top: 2rem; }
  @media (min-width: 768px) { .cg-steps { grid-template-columns: repeat(3, 1fr); } }
  .cg-step { text-align: center; padding: 1.5rem; background: var(--color-surface); border-radius: 1rem; border: 1px solid var(--color-border-subtle); }
  .cg-step__num { width: 40px; height: 40px; border-radius: 50%; background: var(--color-accent); color: #fff; font-weight: 800; display: flex; align-items: center; justify-content: center; margin: 0 auto 1rem; }
  .cg-step h3 { margin-bottom: 0.5rem; font-size: 1.0625rem; }
  .cg-step p { color: var(--color-text-secondary); font-size: 0.9375rem; }

  .cg-scenario { font-size: 1.25rem; color: var(--color-text-primary); font-weight: 600; line-height: 1.5; text-align: center; font-style: italic; }

  .cg-trades { display: grid; grid-template-columns: repeat(2, 1fr); gap: 0.75rem; margin-top: 2rem; }
  @media (min-width: 640px) { .cg-trades { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .cg-trades { grid-template-columns: repeat(4, 1fr); } }
  .cg-trade-link { display: flex; align-items: center; gap: 0.5rem; padding: 0.75rem 1rem; background: var(--color-surface); border: 1px solid var(--color-border-subtle); border-radius: 0.75rem; color: var(--color-text-secondary); font-size: 0.85rem; font-weight: 500; text-decoration: none; transition: all 150ms; }
  .cg-trade-link:hover { border-color: var(--color-accent); color: var(--color-text-primary); }
  .cg-trade-link svg { color: var(--color-accent); flex-shrink: 0; }
</style>
