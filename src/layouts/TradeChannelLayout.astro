---
/**
 * TradeChannelLayout.astro
 * Template for: Trade × Channel pages (143 pages) — the leanest pages
 * e.g. /ai-phone-answering-for-plumbers
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import HeroJaina from '../components/HeroJaina.astro';
import WidgetJaina from '../components/WidgetJaina.astro';
import CTAButton from '../components/CTAButton.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

interface Props {
  frontmatter: {
    title: string;
    metaTitle: string;
    metaDescription: string;
    canonicalUrl?: string;
    heroHeadline: string;
    heroSubhead: string;
    heroAIText: string;
    price?: string;
    trade: string;
    tradeSlug: string;
    tradeAdjective: string;
    channelSlug: string;
    channelName: string;
    // Scenario
    scenario: string;
    // How It Works
    step1Title: string; step1Text: string;
    step2Title: string; step2Text: string;
    step3Title: string; step3Text: string;
    // FAQs — main content
    faqs: Array<{ question: string; answer: string }>;
    // Trade hub link
    tradeHubHref: string;
    tradeHubName: string;
    widgetTrade?: string;
    widgetGoal?: string;
  };
}

const { frontmatter } = Astro.props;
const fm = frontmatter;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fm.metaTitle}</title>
  <meta name="description" content={fm.metaDescription} />
  {fm.canonicalUrl && <link rel="canonical" href={fm.canonicalUrl} />}
  <meta property="og:title" content={fm.metaTitle} />
  <meta property="og:description" content={fm.metaDescription} />
  <meta property="og:url" content={fm.canonicalUrl} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <SchemaOrg
    type="service"
    pageTitle={fm.title}
    pageDescription={fm.metaDescription}
    pageUrl={fm.canonicalUrl}
    serviceName={fm.channelName + ' for ' + fm.trade}
    serviceDescription={fm.metaDescription}
    price="99"
    audience={fm.trade}
    parentService={'AI Receptionist for ' + fm.trade}
    parentServiceUrl={fm.tradeHubHref}
    breadcrumbs={[
      { name: 'Home', url: '/' },
      { name: 'AI Receptionist', url: '/ai-receptionist-for-tradesmen' },
      { name: 'AI Receptionist for ' + fm.trade, url: fm.tradeHubHref },
      { name: fm.channelName, url: fm.canonicalUrl || '' },
    ]}
  />
</head>
<body>
  <Header />

  <main id="main-content" style="padding-top: 64px;">

    <!-- 1. HERO — Stacked -->
    <section class="tc-hero">
      <div class="tc-hero__inner">
        <div class="tc-hero__stacked">
          <h1>{fm.heroHeadline}</h1>
          <p class="tc-hero__subhead">{fm.heroSubhead}</p>
          <div class="tc-hero__trust-row">
            <span class="tc-hero__done-tag">✓ 100% done for you</span>
            <span class="tc-hero__price-tag">Only £99/month</span>
            <span class="tc-hero__guarantee-tag">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              30-day money back guarantee
            </span>
          </div>
          <div class="tc-hero__jaina">
            <HeroJaina showHeroAI={true} heroAIText={fm.heroAIText} />
          </div>
        </div>
      </div>
    </section>

    <!-- 2. SCENARIO -->
    <section class="tc-section tc-section--alt">
      <div class="tc-container tc-container--narrow">
        <p class="tc-scenario">{fm.scenario}</p>
      </div>
    </section>
    <section class="tc-section">
      <div class="tc-container">
        <h2 class="tc-section__title">How It Works</h2>
        <div class="tc-steps">
          <div class="tc-step"><div class="tc-step__num">1</div><h3>{fm.step1Title}</h3><p>{fm.step1Text}</p></div>
          <div class="tc-step"><div class="tc-step__num">2</div><h3>{fm.step2Title}</h3><p>{fm.step2Text}</p></div>
          <div class="tc-step"><div class="tc-step__num">3</div><h3>{fm.step3Title}</h3><p>{fm.step3Text}</p></div>
        </div>
      </div>
    </section>

    <!-- 4. FAQs — MAIN CONTENT -->
    {fm.faqs && fm.faqs.length > 0 && (
      <section class="tc-section tc-section--alt">
        <div class="tc-container">
          <h2 class="tc-section__title">Frequently Asked Questions</h2>
          <FAQAccordion faqs={fm.faqs} />
        </div>
      </section>
    )}

    <!-- 5. CTA -->
    <section class="tc-section" style="text-align: center;">
      <div class="tc-container tc-container--narrow">
        <h2>Ready To Get Started?</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: 1.5rem;">30-day money back guarantee. No contracts.</p>
        <CTAButton buttonText="Get Started" buttonLink="/get-started" showPrice={true} priceText={fm.price || '£299 setup · £99/month'} showGuarantee={true} size="large" />
      </div>
    </section>

    <!-- 6. TRADE HUB LINK -->
    <section class="tc-section tc-section--alt" style="text-align: center; padding: 2rem 1rem;">
      <a href={fm.tradeHubHref} class="tc-hub-link">
        See all AI Receptionist features for {fm.trade} →
      </a>
    </section>

  </main>

  <Footer />
  <CookieConsent />
  <WidgetJaina widgetTrade={fm.widgetTrade || fm.tradeAdjective} widgetGoal={fm.widgetGoal || 'business'} />
</body>
</html>

<style>
  .tc-hero { background: var(--color-primary); padding: 2.5rem 1rem 2rem; }
  .tc-hero__inner { max-width: 72rem; margin: 0 auto; }
  .tc-hero__stacked { display: flex; flex-direction: column; align-items: center; text-align: center; }
  @media (min-width: 1024px) { .tc-hero { padding: 3.5rem 2rem 2rem; } }
  .tc-hero__subhead { font-size: 1.0625rem; color: var(--color-text-secondary); margin-bottom: 1rem; max-width: 36rem; line-height: 1.6; }
  .tc-hero__trust-row { display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .tc-hero__price-tag { font-size: 1.05rem; font-weight: 700; color: var(--color-text-primary); }
  .tc-hero__done-tag { font-size: 0.95rem; font-weight: 600; color: var(--color-accent); }
  .tc-hero__guarantee-tag { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.9rem; font-weight: 600; color: var(--color-trust); }

  .tc-section { padding: 2.5rem 1rem; }
  @media (min-width: 768px) { .tc-section { padding: 4rem 2rem; } }
  .tc-section--alt { background: var(--color-secondary); }
  .tc-container { max-width: 72rem; margin: 0 auto; }
  .tc-container--narrow { max-width: 42rem; margin: 0 auto; }
  .tc-section__title { text-align: center; margin-bottom: 0.75rem; }

  .tc-scenario { font-size: 1.125rem; color: var(--color-text-primary); font-weight: 600; line-height: 1.5; text-align: center; font-style: italic; }

  .tc-steps { display: grid; grid-template-columns: 1fr; gap: 1.5rem; margin-top: 1.5rem; }
  @media (min-width: 768px) { .tc-steps { grid-template-columns: repeat(3, 1fr); } }
  .tc-step { text-align: center; padding: 1.25rem; background: var(--color-surface); border-radius: 1rem; border: 1px solid var(--color-border-subtle); }
  .tc-step__num { width: 36px; height: 36px; border-radius: 50%; background: var(--color-accent); color: #fff; font-weight: 800; display: flex; align-items: center; justify-content: center; margin: 0 auto 0.75rem; font-size: 1rem; }
  .tc-step h3 { margin-bottom: 0.375rem; font-size: 1rem; }
  .tc-step p { color: var(--color-text-secondary); font-size: 0.875rem; }

  .tc-hub-link { color: var(--color-accent); font-weight: 600; font-size: 1rem; text-decoration: none; transition: color 150ms; }
  .tc-hub-link:hover { color: var(--color-accent-hover); }
</style>
