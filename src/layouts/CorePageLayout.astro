---
/**
 * CorePageLayout.astro
 * Template for: About, contact, legal, utility pages (14 pages)
 * Flexible layout — content defines sections via slot.
 * Most do NOT have Jaina in the hero.
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import HeroJaina from '../components/HeroJaina.astro';
import WidgetJaina from '../components/WidgetJaina.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

interface Props {
  frontmatter: {
    title: string;
    metaTitle: string;
    metaDescription: string;
    canonicalUrl?: string;
    showHeroAI?: boolean;
    heroAIText?: string;
    heroHeadline?: string;
    heroSubhead?: string;
    widgetTrade?: string;
    widgetGoal?: string;
  };
}

const { frontmatter } = Astro.props;
const fm = frontmatter;
const showJaina = fm.showHeroAI === true;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fm.metaTitle}</title>
  <meta name="description" content={fm.metaDescription} />
  {fm.canonicalUrl && <link rel="canonical" href={fm.canonicalUrl} />}
  <meta property="og:title" content={fm.metaTitle} />
  <meta property="og:description" content={fm.metaDescription} />
  <meta property="og:url" content={fm.canonicalUrl} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <SchemaOrg
    type="core"
    pageTitle={fm.title}
    pageDescription={fm.metaDescription}
    pageUrl={fm.canonicalUrl}
  />
</head>
<body>
  <Header />

  <main id="main-content" style="padding-top: 64px;">

    <!-- HERO -->
    <section class="core-hero">
      <div class="core-hero__inner">
        {showJaina ? (
          <div class="core-hero__stacked">
            {fm.heroHeadline && <h1>{fm.heroHeadline}</h1>}
            {fm.heroSubhead && <p class="core-hero__subhead">{fm.heroSubhead}</p>}
            <div class="core-hero__jaina">
              <HeroJaina showHeroAI={true} heroAIText={fm.heroAIText || ''} />
            </div>
          </div>
        ) : (
          <div class="core-hero__text core-hero__text--centered">
            {fm.heroHeadline && <h1>{fm.heroHeadline}</h1>}
            {fm.heroSubhead && <p class="core-hero__subhead">{fm.heroSubhead}</p>}
          </div>
        )}
      </div>
    </section>

    <!-- CONTENT (slot — each page defines its own sections) -->
    <div class="core-content">
      <slot />
    </div>

  </main>

  <Footer />
  <CookieConsent />
  <WidgetJaina widgetTrade={fm.widgetTrade || ''} widgetGoal={fm.widgetGoal || ''} />
</body>
</html>

<style>
  .core-hero { background: var(--color-primary); padding: 2.5rem 1rem 2rem; }
  .core-hero__inner { max-width: 72rem; margin: 0 auto; }
  .core-hero__stacked { display: flex; flex-direction: column; align-items: center; text-align: center; }
  @media (min-width: 1024px) { .core-hero { padding: 3.5rem 2rem 2rem; } }
  .core-hero__text--centered { text-align: center; max-width: 42rem; margin: 0 auto; }
  .core-hero__subhead { font-size: 1.1rem; color: var(--color-text-secondary); margin-top: 0.75rem; max-width: 36rem; line-height: 1.6; }
  .core-hero__text { text-align: center; }
  .core-hero__subhead { margin-left: auto; margin-right: auto; }

  /* Core content — global styling for slotted content */
  .core-content {
    color: var(--color-text-secondary);
  }

  .core-content :global(section) {
    padding: 3rem 1rem;
  }

  @media (min-width: 768px) {
    .core-content :global(section) {
      padding: 4rem 2rem;
    }
  }

  .core-content :global(.core-section--alt) {
    background: var(--color-secondary);
  }

  .core-content :global(.core-container) {
    max-width: 72rem;
    margin: 0 auto;
  }

  .core-content :global(.core-container--narrow) {
    max-width: 42rem;
    margin: 0 auto;
  }

  .core-content :global(.core-container--text) {
    max-width: 56rem;
    margin: 0 auto;
  }

  /* Legal page styles */
  .core-content :global(.legal-content) {
    max-width: 42rem;
    margin: 0 auto;
    font-size: 0.9375rem;
    line-height: 1.8;
  }

  .core-content :global(.legal-content h2) {
    margin-top: 2.5rem;
    margin-bottom: 0.75rem;
    font-size: 1.25rem;
  }

  .core-content :global(.legal-content h3) {
    margin-top: 1.5rem;
    margin-bottom: 0.5rem;
    font-size: 1.0625rem;
  }

  .core-content :global(.legal-content p) {
    margin-bottom: 1rem;
  }

  .core-content :global(.legal-content ul) {
    padding-left: 1.5rem;
    margin-bottom: 1rem;
  }

  .core-content :global(.legal-content li) {
    margin-bottom: 0.375rem;
  }

  /* Contact form styles */
  .core-content :global(.contact-form) {
    max-width: 32rem;
    margin: 0 auto;
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .core-content :global(.form-field) {
    display: flex;
    flex-direction: column;
    gap: 0.375rem;
  }

  .core-content :global(.form-field label) {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
  }

  .core-content :global(.form-field input),
  .core-content :global(.form-field textarea),
  .core-content :global(.form-field select) {
    padding: 0.75rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.5rem;
    color: var(--color-text-primary);
    font-size: 1rem;
    font-family: inherit;
    transition: border-color 150ms;
  }

  .core-content :global(.form-field input:focus),
  .core-content :global(.form-field textarea:focus),
  .core-content :global(.form-field select:focus) {
    outline: none;
    border-color: var(--color-accent);
  }

  .core-content :global(.form-field textarea) {
    resize: vertical;
    min-height: 120px;
  }

  /* Pricing cards */
  .core-content :global(.pricing-card) {
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 1rem;
    padding: 2rem;
    margin-bottom: 1.5rem;
  }

  .core-content :global(.pricing-card__name) {
    font-size: 1.25rem;
    font-weight: 800;
    color: var(--color-text-primary);
    margin-bottom: 0.5rem;
  }

  .core-content :global(.pricing-card__price) {
    font-size: 1.5rem;
    font-weight: 700;
    color: var(--color-accent);
    margin-bottom: 1rem;
  }

  .core-content :global(.pricing-card__features) {
    list-style: none;
    padding: 0;
    margin: 0 0 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .core-content :global(.pricing-card__features li) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.9375rem;
    color: var(--color-text-secondary);
  }

  .core-content :global(.pricing-card__features li::before) {
    content: '✓';
    color: var(--color-trust);
    font-weight: 700;
  }
</style>
