---
/**
 * SolutionPainPointLayout.astro
 * Template for: Solution + problem pages (29 pages)
 * e.g. /ai-lead-generation-for-plumbers, /tradesmen-missing-calls
 */
import '../styles/global.css';
import pricing from '../data/pricing.json';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import HeroJaina from '../components/HeroJaina.astro';
import WidgetJaina from '../components/WidgetJaina.astro';
import CTAButton from '../components/CTAButton.astro';
import GuaranteeBadge from '../components/GuaranteeBadge.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import SchemaOrg from '../components/SchemaOrg.astro';

interface Props {
  frontmatter: {
    title: string;
    metaTitle: string;
    metaDescription: string;
    canonicalUrl?: string;
    heroHeadline: string;
    heroSubhead: string;
    heroAIText: string;
    price?: string;
    // The Problem
    problemHeadline: string;
    problemText: string;
    // Cost of Inaction
    costHeadline?: string;
    costText?: string;
    // The Solution
    solutionHeadline: string;
    solutionText: string;
    solutionLinks?: Array<{ name: string; href: string; description: string }>;
    // Flywheel (optional, solution pages only)
    showFlywheel?: boolean;
    // FAQs
    faqs: Array<{ question: string; answer: string }>;
    widgetTrade?: string;
    widgetGoal?: string;
  };
}

const { frontmatter } = Astro.props;
const fm = frontmatter;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fm.metaTitle}</title>
  <meta name="description" content={fm.metaDescription} />
  {fm.canonicalUrl && <link rel="canonical" href={fm.canonicalUrl} />}
  <meta property="og:title" content={fm.metaTitle} />
  <meta property="og:description" content={fm.metaDescription} />
  <meta property="og:url" content={fm.canonicalUrl} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
  <SchemaOrg
    type="service"
    pageTitle={fm.title}
    pageDescription={fm.metaDescription}
    pageUrl={fm.canonicalUrl}
    serviceName={fm.title}
    serviceDescription={fm.metaDescription}
    price={String(pricing.receptionist.monthlyPrice)}
    breadcrumbs={[
      { name: 'Home', url: '/' },
      { name: fm.title, url: fm.canonicalUrl || '' },
    ]}
  />
</head>
<body>
  <Header />

  <main id="main-content" style="padding-top: 64px;">

    <!-- 1. HERO — Stacked -->
    <section class="sp-hero">
      <div class="sp-hero__inner">
        <div class="sp-hero__stacked">
          <h1>{fm.heroHeadline}</h1>
          <p class="sp-hero__subhead">{fm.heroSubhead}</p>          <div class="sp-hero__jaina">
            <HeroJaina showHeroAI={true} heroAIText={fm.heroAIText} />
          </div>

          <div class="sp-hero__trust-row">
            <span class="sp-hero__done-tag">✓ 100% done for you</span>
            <span class="sp-hero__done-tag">🇬🇧 UK business</span>
            <span class="sp-hero__price-tag">Only {pricing.receptionist.formatted.monthly}</span>
            <span class="sp-hero__guarantee-tag">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              30-day money back guarantee
            </span>
          </div>
        </div>
      </div>
    </section>

    <!-- 2. THE PROBLEM -->
    <section class="sp-section sp-section--alt">
      <div class="sp-container sp-container--narrow">
        <h2 class="sp-section__title">{fm.problemHeadline}</h2>
        <p class="sp-problem-text">{fm.problemText}</p>
      </div>
    </section>

    <!-- 3. COST OF INACTION -->
    {fm.costText && (
      <section class="sp-section sp-cost">
        <div class="sp-container sp-container--narrow">
          <h2 class="sp-section__title">{fm.costHeadline || 'What It Costs You'}</h2>
          <p class="sp-cost__text">{fm.costText}</p>
        </div>
      </section>
    )}

    <!-- 4. THE SOLUTION -->
    <section class="sp-section sp-section--alt">
      <div class="sp-container">
        <h2 class="sp-section__title">{fm.solutionHeadline}</h2>
        <p class="sp-solution-text">{fm.solutionText}</p>
        {fm.solutionLinks && fm.solutionLinks.length > 0 && (
          <div class="sp-solution-links">
            {fm.solutionLinks.map(link => (
              <a href={link.href} class="sp-solution-card">
                <h3>{link.name}</h3>
                <p>{link.description}</p>
                <span class="sp-solution-card__link">Learn more →</span>
              </a>
            ))}
          </div>
        )}
      </div>
    </section>

    <!-- 5. FLYWHEEL (optional) -->
    {fm.showFlywheel && (
      <section class="sp-section">
        <div class="sp-container sp-container--narrow" style="text-align: center;">
          <h2 class="sp-section__title">The Lead Generation Flywheel</h2>
          <div class="sp-flywheel">
            <div class="sp-flywheel__step">
              <div class="sp-flywheel__icon">🌐</div>
              <span>Website ranks on Google</span>
            </div>
            <div class="sp-flywheel__arrow">→</div>
            <div class="sp-flywheel__step">
              <div class="sp-flywheel__icon">📞</div>
              <span>Leads come in</span>
            </div>
            <div class="sp-flywheel__arrow">→</div>
            <div class="sp-flywheel__step">
              <div class="sp-flywheel__icon">🤖</div>
              <span>Your AI receptionist answers instantly</span>
            </div>
            <div class="sp-flywheel__arrow">→</div>
            <div class="sp-flywheel__step">
              <div class="sp-flywheel__icon">🔧</div>
              <span>You complete the work</span>
            </div>
            <div class="sp-flywheel__arrow">→</div>
            <div class="sp-flywheel__step">
              <div class="sp-flywheel__icon">📸</div>
              <span>Send photos → AI creates content</span>
            </div>
            <div class="sp-flywheel__arrow">→</div>
            <div class="sp-flywheel__step">
              <div class="sp-flywheel__icon">📈</div>
              <span>More visibility → More leads</span>
            </div>
          </div>
          <p class="sp-flywheel__note">Every job makes the next job easier to win. ♻️</p>
        </div>
      </section>
    )}

    <!-- 6. FAQs -->
    {fm.faqs && fm.faqs.length > 0 && (
      <section class="sp-section sp-section--alt">
        <div class="sp-container">
          <h2 class="sp-section__title">Frequently Asked Questions</h2>
          <FAQAccordion faqs={fm.faqs} />
        </div>
      </section>
    )}

    <!-- 7. CTA -->
    <section class="sp-section" style="text-align: center;">
      <div class="sp-container sp-container--narrow">
        <h2>Ready To Fix This?</h2>
        <p style="color: var(--color-text-secondary); margin-bottom: 1.5rem;">30-day money back guarantee. No contracts.</p>
        <CTAButton buttonText="Get Started" buttonLink="/get-started" showGuarantee={true} size="large" />
      </div>
    </section>

  </main>

  <Footer />
  <CookieConsent />
  <WidgetJaina widgetTrade={fm.widgetTrade || ''} widgetGoal={fm.widgetGoal || 'leads'} />
</body>
</html>

<style>
  .sp-hero { background: var(--color-primary); padding: 3rem 1rem 2.5rem; }
  .sp-hero__inner { max-width: 72rem; margin: 0 auto; }
  .sp-hero__stacked { display: flex; flex-direction: column; align-items: center; text-align: center; }
  @media (min-width: 1024px) { .sp-hero { padding: 4rem 2rem 2.5rem; } }
  .sp-hero__subhead { font-size: 1.1rem; color: var(--color-text-secondary); margin-bottom: 1rem; max-width: 36rem; line-height: 1.6; }
  .sp-hero__trust-row { margin-top: 1.25rem; display: flex; align-items: center; justify-content: center; gap: 0.75rem; flex-wrap: wrap; margin-bottom: 0.5rem; }
  .sp-hero__price-tag { font-size: 1.05rem; font-weight: 700; color: var(--color-text-primary); }
  .sp-hero__done-tag { font-size: 0.95rem; font-weight: 600; color: var(--color-accent); }
  .sp-hero__guarantee-tag { display: inline-flex; align-items: center; gap: 0.35rem; font-size: 0.9rem; font-weight: 600; color: var(--color-trust); }

  .sp-section { padding: 3rem 1rem; }
  @media (min-width: 768px) { .sp-section { padding: 5rem 2rem; } }
  .sp-section--alt { background: var(--color-secondary); }
  .sp-container { max-width: 72rem; margin: 0 auto; }
  .sp-container--narrow { max-width: 42rem; margin: 0 auto; }
  .sp-section__title { text-align: center; margin-bottom: 1rem; }

  .sp-problem-text { font-size: 1.125rem; color: var(--color-text-secondary); line-height: 1.7; text-align: center; }
  .sp-cost { text-align: center; }
  .sp-cost__text { font-size: 1.25rem; color: var(--color-text-primary); font-weight: 600; line-height: 1.5; }
  .sp-solution-text { text-align: center; color: var(--color-text-secondary); margin-bottom: 2rem; }

  .sp-solution-links { display: grid; grid-template-columns: 1fr; gap: 1rem; margin-top: 2rem; }
  @media (min-width: 768px) { .sp-solution-links { grid-template-columns: repeat(3, 1fr); } }
  .sp-solution-card { padding: 1.5rem; background: var(--color-surface); border: 1px solid var(--color-border-subtle); border-radius: 1rem; text-decoration: none; transition: border-color 150ms; }
  .sp-solution-card:hover { border-color: var(--color-accent); }
  .sp-solution-card h3 { font-size: 1rem; font-weight: 700; color: var(--color-text-primary); margin-bottom: 0.5rem; }
  .sp-solution-card p { font-size: 0.875rem; color: var(--color-text-secondary); margin-bottom: 0.75rem; }
  .sp-solution-card__link { font-size: 0.875rem; color: var(--color-accent); font-weight: 600; }

  /* Flywheel */
  .sp-flywheel { display: flex; flex-wrap: wrap; justify-content: center; align-items: center; gap: 0.75rem; margin: 2rem 0; }
  .sp-flywheel__step { display: flex; flex-direction: column; align-items: center; gap: 0.375rem; padding: 1rem; background: var(--color-surface); border-radius: 0.75rem; border: 1px solid var(--color-border-subtle); min-width: 120px; }
  .sp-flywheel__icon { font-size: 1.5rem; }
  .sp-flywheel__step span { font-size: 0.8rem; color: var(--color-text-secondary); text-align: center; }
  .sp-flywheel__arrow { color: var(--color-accent); font-weight: 700; font-size: 1.25rem; }
  .sp-flywheel__note { color: var(--color-text-muted); font-size: 0.9rem; margin-top: 1rem; }
</style>
