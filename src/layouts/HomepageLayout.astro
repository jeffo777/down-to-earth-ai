---
/**
 * HomepageLayout.astro
 * Template for: / (1 page)
 * Focus: AI Receptionist ONLY. One product. One price. One CTA.
 */
import '../styles/global.css';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import CookieConsent from '../components/CookieConsent.astro';
import HeroJaina from '../components/HeroJaina.astro';
import WidgetJaina from '../components/WidgetJaina.astro';
import CTAButton from '../components/CTAButton.astro';
import GuaranteeBadge from '../components/GuaranteeBadge.astro';
import FAQAccordion from '../components/FAQAccordion.astro';
import TestimonialSlider from '../components/TestimonialSlider.astro';
import trades from '../data/trades.json';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    metaTitle: string;
    metaDescription: string;
    canonicalUrl?: string;
    heroHeadline: string;
    heroSubhead: string;
    heroAIText: string;
    heroGreeting?: string;
    heroPrice?: string;
    price: string;
    guaranteeText?: string;
    // How It Works
    step1Title: string;
    step1Text: string;
    step2Title: string;
    step2Text: string;
    step3Title: string;
    step3Text: string;
    // The Problem
    problemText: string;
    // What's Included channels
    channels: Array<{ name: string; description: string; icon: string; link?: string }>;
    // Founder's Note
    foundersNote: string;
    founderName?: string;
    // FAQs
    faqs: Array<{ question: string; answer: string }>;
  };
}

const { frontmatter } = Astro.props;
const fm = frontmatter;
---

<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{fm.metaTitle}</title>
  <meta name="description" content={fm.metaDescription} />
  {fm.canonicalUrl && <link rel="canonical" href={fm.canonicalUrl} />}
  <meta property="og:title" content={fm.metaTitle} />
  <meta property="og:description" content={fm.metaDescription} />
  <meta property="og:url" content={fm.canonicalUrl || 'https://downtoearthai.co.uk'} />
  <meta property="og:type" content="website" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet" />
</head>
<body>
  <Header />

  <main id="main-content" style="padding-top: 64px;">

    <!-- 1. HERO — Tight stack: Title → Subtitle → Price+Guarantee → Headshot → CTA -->
    <section class="hp-hero">
      <div class="hp-hero__inner">
        <div class="hp-hero__stacked">
          <h1 class="hp-hero__headline">{fm.heroHeadline}</h1>
          <p class="hp-hero__subhead">{fm.heroSubhead}</p>
          <div class="hp-hero__trust-row">
            <span class="hp-hero__done-tag">✓ 100% done for you</span>
            {fm.heroPrice && (
              <span class="hp-hero__price-tag">Only {fm.heroPrice}</span>
            )}
            <span class="hp-hero__guarantee-tag">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>
              30-day money back guarantee
            </span>
          </div>
          <div class="hp-hero__jaina">
            <HeroJaina showHeroAI={true} heroAIText={fm.heroAIText} heroGreeting={fm.heroGreeting} />
          </div>
        </div>
      </div>
    </section>

    <!-- 2. HOW IT WORKS -->
    <section class="hp-section hp-section--alt">
      <div class="hp-container">
        <h2 class="hp-section__title">How It Works</h2>
        <div class="hp-steps">
          <div class="hp-step">
            <div class="hp-step__number">1</div>
            <h3 class="hp-step__title">{fm.step1Title}</h3>
            <p class="hp-step__text">{fm.step1Text}</p>
          </div>
          <div class="hp-step">
            <div class="hp-step__number">2</div>
            <h3 class="hp-step__title">{fm.step2Title}</h3>
            <p class="hp-step__text">{fm.step2Text}</p>
          </div>
          <div class="hp-step">
            <div class="hp-step__number">3</div>
            <h3 class="hp-step__title">{fm.step3Title}</h3>
            <p class="hp-step__text">{fm.step3Text}</p>
          </div>
        </div>
      </div>
    </section>

    <!-- 3. THE PROBLEM -->
    <section class="hp-section hp-problem">
      <div class="hp-container hp-container--narrow">
        <p class="hp-problem__text">{fm.problemText}</p>
      </div>
    </section>

    <!-- 4. WHAT'S INCLUDED -->
    {fm.channels && fm.channels.length > 0 && (
      <section class="hp-section hp-section--alt">
        <div class="hp-container">
          <h2 class="hp-section__title">What's Included</h2>
          <div class="hp-channels">
            {fm.channels.map(channel => (
              channel.link ? (
                <a href={channel.link} class="hp-channel hp-channel--link">
                  <div class="hp-channel__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <div>
                    <h3 class="hp-channel__name">{channel.name}</h3>
                    <p class="hp-channel__desc">{channel.description}</p>
                  </div>
                </a>
              ) : (
                <div class="hp-channel">
                  <div class="hp-channel__icon">
                    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                  </div>
                  <div>
                    <h3 class="hp-channel__name">{channel.name}</h3>
                    <p class="hp-channel__desc">{channel.description}</p>
                  </div>
                </div>
              )
            ))}
          </div>
        </div>
      </section>
    )}

    <!-- 5. FOUNDER'S NOTE -->
    <section class="hp-section">
      <div class="hp-container hp-container--narrow">
        <div class="hp-founder">
          <div class="hp-founder__avatar">
            <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
          </div>
          <blockquote class="hp-founder__quote">
            <p>{fm.foundersNote}</p>
          </blockquote>
          {fm.founderName && <p class="hp-founder__name">— {fm.founderName}</p>}
          <div class="hp-founder__badge">
            <GuaranteeBadge />
          </div>
        </div>
      </div>
    </section>

    <!-- 6. SOCIAL PROOF -->
    <section class="hp-section hp-section--alt">
      <div class="hp-container">
        <TestimonialSlider />
      </div>
    </section>

    <!-- 7. TRADE GRID -->
    <section class="hp-section">
      <div class="hp-container">
        <h2 class="hp-section__title">Your AI Receptionist Works For Every Trade</h2>
        <div class="hp-trades">
          {trades.map(trade => (
            <a href={`/ai-receptionist-for-${trade.slug}`} class="hp-trade">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>
              <span>{trade.name}</span>
            </a>
          ))}
        </div>
      </div>
    </section>

    <!-- 8. FINAL CTA -->
    <section class="hp-section hp-section--alt hp-final-cta">
      <div class="hp-container hp-container--narrow" style="text-align: center;">
        <h2>Ready To Stop Missing Jobs?</h2>
        <p class="hp-final-cta__sub">Get your AI receptionist set up for your business in under 24 hours.</p>
        <CTAButton
          buttonText="Get Started"
          buttonLink="/get-started"
          showPrice={true}
          priceText={fm.price}
          showGuarantee={true}
          size="large"
        />
      </div>
    </section>

    <!-- FAQs (if provided) -->
    {fm.faqs && fm.faqs.length > 0 && (
      <section class="hp-section">
        <div class="hp-container">
          <h2 class="hp-section__title">Frequently Asked Questions</h2>
          <FAQAccordion faqs={fm.faqs} />
        </div>
      </section>
    )}

  </main>

  <Footer />
  <CookieConsent />
  <WidgetJaina widgetTrade="" widgetGoal="leads" />
</body>
</html>

<style>
  /* Hero */
  .hp-hero {
    background: var(--color-primary);
    padding: 3rem 1rem 2.5rem;
  }
  .hp-hero__inner { max-width: 72rem; margin: 0 auto; }
  .hp-hero__stacked {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    width: 100%;
  }
  .hp-hero__headline {
    font-size: 2rem;
    line-height: 1.15;
    margin-bottom: 1rem;
    max-width: 48rem;
    text-align: center;
    width: 100%;
  }
  @media (min-width: 768px) {
    .hp-hero__headline { font-size: 2.75rem; }
  }
  @media (min-width: 1024px) {
    .hp-hero { padding: 4rem 2rem 2.5rem; }
    .hp-hero__headline { font-size: 3.25rem; }
  }
  .hp-hero__subhead {
    font-size: 1.1rem;
    color: var(--color-text-secondary);
    margin-bottom: 1.25rem;
    max-width: 38rem;
    line-height: 1.6;
    text-align: center;
  }
  @media (min-width: 768px) {
    .hp-hero__subhead { font-size: 1.2rem; }
  }
  .hp-hero__trust-row {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 0.75rem;
  }
  .hp-hero__price-tag {
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text-primary);
  }
  .hp-hero__done-tag {
    font-size: 0.95rem; font-weight: 600; color: var(--color-accent);
  }
  .hp-hero__guarantee-tag {
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-trust);
  }

  /* Sections */
  .hp-section { padding: 3rem 1rem; }
  @media (min-width: 768px) { .hp-section { padding: 5rem 2rem; } }
  .hp-section--alt { background: var(--color-secondary); }
  .hp-container { max-width: 72rem; margin: 0 auto; }
  .hp-container--narrow { max-width: 42rem; margin: 0 auto; }
  .hp-section__title {
    text-align: center;
    margin-bottom: 0.75rem;
  }
  .hp-section__subtitle {
    text-align: center;
    color: var(--color-text-muted);
    margin-bottom: 2rem;
  }

  /* How It Works Steps */
  .hp-steps {
    display: grid;
    grid-template-columns: 1fr;
    gap: 2rem;
    margin-top: 2rem;
  }
  @media (min-width: 768px) {
    .hp-steps { grid-template-columns: repeat(3, 1fr); }
  }
  .hp-step {
    text-align: center;
    padding: 1.5rem;
    background: var(--color-surface);
    border-radius: 1rem;
    border: 1px solid var(--color-border-subtle);
  }
  .hp-step__number {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--color-accent);
    color: #fff;
    font-weight: 800;
    font-size: 1.125rem;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
  }
  .hp-step__title {
    margin-bottom: 0.5rem;
    font-size: 1.125rem;
  }
  .hp-step__text { color: var(--color-text-secondary); font-size: 0.9375rem; }

  /* Problem */
  .hp-problem { text-align: center; }
  .hp-problem__text {
    font-size: 1.25rem;
    color: var(--color-text-primary);
    font-weight: 600;
    line-height: 1.5;
  }
  @media (min-width: 768px) { .hp-problem__text { font-size: 1.5rem; } }

  /* Channels */
  .hp-channels {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
    margin-top: 2rem;
  }
  @media (min-width: 768px) { .hp-channels { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .hp-channels { grid-template-columns: repeat(4, 1fr); } }
  .hp-channel {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 1rem;
    background: var(--color-surface);
    border-radius: 0.75rem;
    border: 1px solid var(--color-border-subtle);
  }
  .hp-channel__icon {
    flex-shrink: 0;
    color: var(--color-accent);
    margin-top: 0.125rem;
  }
  .hp-channel__name {
    font-size: 0.875rem;
    font-weight: 600;
    color: var(--color-text-primary);
    margin-bottom: 0.25rem;
  }
  .hp-channel__desc { font-size: 0.8rem; color: var(--color-text-muted); }
  a.hp-channel--link {
    text-decoration: none;
    color: inherit;
    transition: border-color 150ms, transform 150ms, background 150ms;
  }
  a.hp-channel--link:hover {
    border-color: var(--color-accent);
    transform: translateY(-2px);
    background: rgba(232, 145, 58, 0.06);
  }

  /* Founder */
  .hp-founder {
    text-align: center;
    padding: 2rem;
    background: var(--color-surface);
    border-radius: 1rem;
    border: 1px solid var(--color-border-subtle);
  }
  .hp-founder__avatar {
    width: 56px;
    height: 56px;
    border-radius: 50%;
    background: var(--color-secondary);
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1rem;
    color: var(--color-accent);
  }
  .hp-founder__quote p {
    color: var(--color-text-secondary);
    font-style: italic;
    font-size: 1rem;
    line-height: 1.7;
  }
  .hp-founder__name {
    color: var(--color-text-muted);
    font-size: 0.875rem;
    margin-top: 0.75rem;
  }
  .hp-founder__badge { margin-top: 1rem; display: flex; justify-content: center; }

  /* Trades Grid */
  .hp-trades {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 0.75rem;
    margin-top: 2rem;
  }
  @media (min-width: 640px) { .hp-trades { grid-template-columns: repeat(3, 1fr); } }
  @media (min-width: 1024px) { .hp-trades { grid-template-columns: repeat(4, 1fr); } }
  .hp-trade {
    display: flex;
    align-items: center;
    gap: 0.625rem;
    padding: 0.875rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border-subtle);
    border-radius: 0.75rem;
    color: var(--color-text-secondary);
    font-size: 0.875rem;
    font-weight: 500;
    text-decoration: none;
    transition: border-color 150ms, color 150ms, background 150ms;
  }
  .hp-trade:hover {
    border-color: var(--color-accent);
    color: var(--color-text-primary);
    background: rgba(232, 145, 58, 0.06);
  }
  .hp-trade svg { color: var(--color-accent); flex-shrink: 0; }

  /* Final CTA */
  .hp-final-cta__sub {
    color: var(--color-text-secondary);
    margin-bottom: 1.5rem;
  }
</style>
